<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="ChineseClassicFont">Noto Sans TC, Microsoft JhengHei, MingLiU, serif</FontFamily>

    <Color x:Key="PaperColor">#F6EDD7</Color>
    <Color x:Key="PanelColor">#FFF7E8</Color>
    <Color x:Key="InkDarkColor">#2A1910</Color>
    <Color x:Key="InkMutedColor">#614B3B</Color>
    <Color x:Key="WoodDarkColor">#6B4C30</Color>
    <Color x:Key="WoodMidColor">#875E37</Color>
    <Color x:Key="WoodLightColor">#A77D4A</Color>
    <Color x:Key="StoneColor">#2E8C72</Color>
    <Color x:Key="MoveHintColor">#6BBF75</Color>
    <Color x:Key="HintFromColor">#F2B632</Color>
    <Color x:Key="HintToColor">#5BC0FF</Color>
    <Color x:Key="LastMoveColor">#F3D89B</Color>
    <Color x:Key="HighlightColor">#EACF75</Color>
    <Color x:Key="BoardLineColor">#4A3620</Color>
    <Color x:Key="BoardSurfaceDarkColor">#7A4E2A</Color>
    <Color x:Key="BoardSurfaceMidColor">#95613A</Color>
    <Color x:Key="BoardSurfaceLightColor">#AD7A50</Color>
    <Color x:Key="BoardPatternDarkColor">#1B3C240E</Color>
    <Color x:Key="BoardFrameColor">#533219</Color>
    <Color x:Key="BoardGridColor">#5A3F29</Color>
    <Color x:Key="BoardOuterBorderColor">#4A2D16</Color>
    <Color x:Key="BoardRiverTextColor">#EEDBC5</Color>
    <Color x:Key="ButtonNormalColor">#C98B41</Color>
    <Color x:Key="ButtonHoverColor">#E1A65A</Color>
    <Color x:Key="ButtonPressedColor">#A46F2E</Color>

    <SolidColorBrush x:Key="PaperBrush" Color="{StaticResource PaperColor}" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource PaperColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkDarkColor}" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMutedColor}" />
    <SolidColorBrush x:Key="WoodDarkBrush" Color="{StaticResource WoodDarkColor}" />
    <SolidColorBrush x:Key="WoodMidBrush" Color="{StaticResource WoodMidColor}" />
    <SolidColorBrush x:Key="WoodLightBrush" Color="{StaticResource WoodLightColor}" />
    <SolidColorBrush x:Key="StoneBrush" Color="{StaticResource StoneColor}" />
    <SolidColorBrush x:Key="MoveHintBrush" Color="{StaticResource MoveHintColor}" />
    <SolidColorBrush x:Key="HintFromBrush" Color="{StaticResource HintFromColor}" />
    <SolidColorBrush x:Key="HintToBrush" Color="{StaticResource HintToColor}" />
    <SolidColorBrush x:Key="LastMoveBrush" Color="{StaticResource LastMoveColor}" />
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}" />
    <SolidColorBrush x:Key="BoardLineBrush" Color="{StaticResource BoardLineColor}" />
    <SolidColorBrush x:Key="BoardGridBrush" Color="{StaticResource BoardGridColor}" />
    <SolidColorBrush x:Key="BoardPatternDarkBrush" Color="{StaticResource BoardPatternDarkColor}" />
    <SolidColorBrush x:Key="BoardFrameBrush" Color="{StaticResource BoardFrameColor}" />
    <SolidColorBrush x:Key="BoardOuterBrush" Color="{StaticResource BoardOuterBorderColor}" />
    <SolidColorBrush x:Key="BoardRiverTextBrush" Color="{StaticResource BoardRiverTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource WoodDarkColor}" />
    <SolidColorBrush x:Key="ButtonBaseBrush" Color="{StaticResource ButtonNormalColor}" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHoverColor}" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="{StaticResource ButtonPressedColor}" />
    <SolidColorBrush x:Key="CardShadowBrush" Color="#55000000" />

    <LinearGradientBrush x:Key="AppBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7F0DE" Offset="0" />
        <GradientStop Color="#EED8B2" Offset="0.55" />
        <GradientStop Color="#F5E9CF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BoardSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BoardSurfaceDarkColor}" Offset="0" />
        <GradientStop Color="{StaticResource BoardSurfaceMidColor}" Offset="0.48" />
        <GradientStop Color="{StaticResource BoardSurfaceLightColor}" Offset="1" />
    </LinearGradientBrush>

    <DrawingBrush x:Key="BoardPatternBrush" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource BoardSurfaceBrush}"
                                 Geometry="M0,0 L20,0 20,20 0,20 Z" />
                <GeometryDrawing Brush="{StaticResource BoardPatternDarkBrush}"
                                 Geometry="M0,0 L20,0 20,4 0,4 Z" />
                <GeometryDrawing Brush="{StaticResource BoardPatternDarkBrush}"
                                 Geometry="M10,10 L20,10 20,12 10,12 Z" />
                <GeometryDrawing Brush="{StaticResource BoardPatternDarkBrush}"
                                 Geometry="M4,0 L6,0 6,20 4,20 Z" />
                <GeometryDrawing Brush="{StaticResource BoardPatternDarkBrush}"
                                 Geometry="M14,0 16,0 16,20 14,20 Z" />
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- 棋子樣式資源 -->
    <SolidColorBrush x:Key="RedPieceTextBrush" Color="#780E0E" />
    <SolidColorBrush x:Key="BlackPieceTextBrush" Color="#E8DCC8" />
    <SolidColorBrush x:Key="RedPieceRingBrush" Color="#5C0F0F" />
    <SolidColorBrush x:Key="BlackPieceRingBrush" Color="#141414" />

    <!-- 紅方棋子底盤 — 象牙白至金棕漸層，模擬木質澤感 -->
    <RadialGradientBrush x:Key="RedPieceDiscBrush"
                         GradientOrigin="0.33,0.30"
                         Center="0.5,0.5"
                         RadiusX="0.65" RadiusY="0.65">
        <GradientStop Color="#FFFEF5" Offset="0" />
        <GradientStop Color="#F7E4A8" Offset="0.48" />
        <GradientStop Color="#C8983C" Offset="1" />
    </RadialGradientBrush>

    <!-- 黑方棋子底盤 — 深炭灰漸層 -->
    <RadialGradientBrush x:Key="BlackPieceDiscBrush"
                         GradientOrigin="0.33,0.30"
                         Center="0.5,0.5"
                         RadiusX="0.65" RadiusY="0.65">
        <GradientStop Color="#565656" Offset="0" />
        <GradientStop Color="#2C2C2C" Offset="0.48" />
        <GradientStop Color="#0A0A0A" Offset="1" />
    </RadialGradientBrush>

    <Style x:Key="AppWindowStyle" TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource ChineseClassicFont}" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource AppBackgroundGradient}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="PanelCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WoodDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource InkDarkColor}"
                                  BlurRadius="14"
                                  Direction="270"
                                  ShadowDepth="4"
                                  Opacity="0.22" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SubPanelCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PaperBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style x:Key="SectionHeadingStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="DemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AnalysisTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource ButtonBaseBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WoodDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="buttonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="buttonBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="buttonBorder" Property="Background" Value="{StaticResource ButtonPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="buttonBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputControlStyle" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource PaperBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style x:Key="DifficultySliderStyle" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource StoneBrush}" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="0,6,0,10" />
    </Style>

    <Style x:Key="PanelGroupStyle" TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="0,10,0,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="12,8,12,12">
                        <DockPanel>
                            <TextBlock Text="{TemplateBinding Header}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       DockPanel.Dock="Top"
                                       Margin="0,0,0,8" />
                            <ContentPresenter />
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
