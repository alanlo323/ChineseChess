<UserControl x:Class="ChineseChess.WPF.Views.EloMatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             xmlns:converters="clr-namespace:ChineseChess.WPF.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EloMatchViewModel}">

    <UserControl.Resources>
        <converters:EloEngineTypeDisplayConverter x:Key="EloEngineTypeDisplayConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,8">

            <!-- ══════════════════════════════════════════════════════
                 區塊一：評估設定
                 ══════════════════════════════════════════════════════ -->
            <TextBlock Text="評估設定"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />

            <Border Style="{StaticResource SubPanelCardStyle}" Margin="0,0,0,10">
                <StackPanel>

                    <!-- 引擎 A / B 並排設定 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- ── 引擎 A ── -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="引擎 A（被評估）"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       Margin="0,0,0,4" />

                            <TextBlock Text="引擎類型"
                                       Style="{StaticResource FormLabelStyle}" />
                            <ComboBox ItemsSource="{Binding AvailableEngineTypes}"
                                      SelectedItem="{Binding SelectedEngineAType}"
                                      Style="{StaticResource InputControlStyle}"
                                      Margin="0,2,0,6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EloEngineTypeDisplayConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="搜尋深度：" />
                                <Run Text="{Binding EngineADepth}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Minimum="1" Maximum="10"
                                    Value="{Binding EngineADepth}"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="0,2,0,6" />

                            <TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="每步時間：" />
                                <Run Text="{Binding EngineATimeLimitSec}" FontWeight="SemiBold" />
                                <Run Text="秒" />
                            </TextBlock>
                            <Slider Minimum="1" Maximum="30"
                                    Value="{Binding EngineATimeLimitSec}"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- 分隔線 -->
                        <Border Grid.Column="1"
                                Width="1"
                                Background="{StaticResource WoodDarkBrush}"
                                Opacity="0.25"
                                Margin="0,4" />

                        <!-- ── 引擎 B ── -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="引擎 B（參照方）"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       Margin="0,0,0,4" />

                            <TextBlock Text="引擎類型"
                                       Style="{StaticResource FormLabelStyle}" />
                            <ComboBox ItemsSource="{Binding AvailableEngineTypes}"
                                      SelectedItem="{Binding SelectedEngineBType}"
                                      Style="{StaticResource InputControlStyle}"
                                      Margin="0,2,0,6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EloEngineTypeDisplayConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="搜尋深度：" />
                                <Run Text="{Binding EngineBDepth}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Minimum="1" Maximum="10"
                                    Value="{Binding EngineBDepth}"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="0,2,0,6" />

                            <TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="每步時間：" />
                                <Run Text="{Binding EngineBTimeLimitSec}" FontWeight="SemiBold" />
                                <Run Text="秒" />
                            </TextBlock>
                            <Slider Minimum="1" Maximum="30"
                                    Value="{Binding EngineBTimeLimitSec}"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- 分隔線 -->
                    <Border Height="1"
                            Background="{StaticResource WoodDarkBrush}"
                            Opacity="0.2"
                            Margin="0,10" />

                    <!-- 對弈局數 -->
                    <TextBlock Style="{StaticResource FormLabelStyle}">
                        <Run Text="對弈局數：" />
                        <Run Text="{Binding TotalGames}" FontWeight="SemiBold" />
                        <Run Text="局" />
                    </TextBlock>
                    <Slider Minimum="10" Maximum="500"
                            Value="{Binding TotalGames}"
                            IsSnapToTickEnabled="True" TickFrequency="10"
                            Style="{StaticResource DifficultySliderStyle}"
                            Margin="0,2,0,8" />

                    <!-- 進階設定（橫排）-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="最大步數：" />
                                <Run Text="{Binding MaxMovesPerGame}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Minimum="50" Maximum="400"
                                    Value="{Binding MaxMovesPerGame}"
                                    IsSnapToTickEnabled="True" TickFrequency="10"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="認輸門檻（分）：" />
                                <Run Text="{Binding ResignThresholdCp}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Minimum="500" Maximum="3000"
                                    Value="{Binding ResignThresholdCp}"
                                    IsSnapToTickEnabled="True" TickFrequency="100"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- 外部引擎提示 -->
                    <TextBlock Foreground="{StaticResource InkMutedBrush}"
                               FontStyle="Italic"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0">
                        <Run Text="外部引擎：" />
                        <Run Text="{Binding ExternalEngineLabel, Mode=OneWay}" />
                        <LineBreak />
                        <Run Text="（如需使用外部引擎，請先至「外部引擎」Tab 設定）" />
                    </TextBlock>

                    <!-- 分隔線 -->
                    <Border Height="1"
                            Background="{StaticResource WoodDarkBrush}"
                            Opacity="0.2"
                            Margin="0,10" />

                    <!-- 控制按鈕 -->
                    <UniformGrid Columns="3" Rows="1">
                        <Button Content="▶ 開始評估"
                                Command="{Binding StartMatchCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="0,0,4,0" />
                        <Button Content="{Binding PauseResumeLabel}"
                                Command="{Binding PauseResumeCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="2,0,2,0" />
                        <Button Content="⏹ 停止"
                                Command="{Binding StopMatchCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="4,0,0,0" />
                    </UniformGrid>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 區塊二：即時進度
                 ══════════════════════════════════════════════════════ -->
            <TextBlock Text="即時進度"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />

            <Border Style="{StaticResource SubPanelCardStyle}" Margin="0,0,0,10">
                <StackPanel>

                    <!-- 進度條 -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding ProgressPercent}"
                                     Height="18"
                                     Foreground="{StaticResource WoodMidBrush}"
                                     Background="{StaticResource PaperBrush}" />
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="12">
                            <Run Text="{Binding CurrentGameNumber, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding TotalGames}" />
                        </TextBlock>
                    </Grid>

                    <!-- 當前局資訊 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}">
                            <Run Text="第 " />
                            <Run Text="{Binding CurrentGameNumber, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" 局 │ " />
                            <Run Text="{Binding CurrentColorInfo, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource FormLabelStyle}"
                                   HorizontalAlignment="Right">
                            <Run Text="當前步數：" />
                            <Run Text="{Binding CurrentMoveCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </Grid>

                    <!-- 當前 FEN -->
                    <TextBlock Text="{Binding CurrentFen}"
                               Foreground="{StaticResource InkMutedBrush}"
                               FontFamily="Consolas"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Visibility="{Binding CurrentFen,
                                   Converter={StaticResource NullToVisibilityConverter}}" />

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 區塊三：統計數據
                 ══════════════════════════════════════════════════════ -->
            <TextBlock Text="統計數據"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />

            <Border Style="{StaticResource SubPanelCardStyle}" Margin="0,0,0,10">
                <StackPanel>

                    <!-- W/L/D 計數 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- A 勝 -->
                        <Border Grid.Column="0"
                                Background="#22448833"
                                CornerRadius="6"
                                Padding="6,4"
                                Margin="0,0,3,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="A 勝"
                                           FontSize="11"
                                           Foreground="#448833"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding EngineAWins}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#336622"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- 和棋 -->
                        <Border Grid.Column="1"
                                Background="#22888844"
                                CornerRadius="6"
                                Padding="6,4"
                                Margin="3,0,3,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="和棋"
                                           FontSize="11"
                                           Foreground="#887733"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding DrawCount}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#665522"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- B 勝 -->
                        <Border Grid.Column="2"
                                Background="#22883333"
                                CornerRadius="6"
                                Padding="6,4"
                                Margin="3,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="B 勝"
                                           FontSize="11"
                                           Foreground="#883333"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding EngineBWins}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#662222"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Elo 差距（主要顯示）-->
                    <Border Background="{StaticResource PaperBrush}"
                            CornerRadius="8"
                            Padding="10,8"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Elo 差距（A 相對於 B）"
                                       Style="{StaticResource FormLabelStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding EloDifferenceText}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource InkBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />

                            <!-- 樣本數不足警告 -->
                            <TextBlock Text="⚠ 樣本數不足 30 局，Elo 估算僅供參考"
                                       FontSize="11"
                                       Foreground="#CC7700"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding IsLowSampleWarning,
                                           Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>

                    <!-- 次要統計 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FormLabelStyle}" Text="A 勝率" />
                            <TextBlock Text="{Binding WinRateText}"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource FormLabelStyle}" Text="平均局長" />
                            <TextBlock Text="{Binding AverageGameLengthText}"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 區塊四：對局記錄
                 ══════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="對局記錄"
                           Style="{StaticResource SectionTitleStyle}" />
                <Button Grid.Column="1"
                        Content="匯出 CSV"
                        Command="{Binding ExportResultsCommand}"
                        Style="{StaticResource CompactButtonStyle}" />
            </Grid>

            <Border Style="{StaticResource SubPanelCardStyle}" Margin="0,0,0,10">
                <ListView ItemsSource="{Binding GameResults}"
                          MaxHeight="280"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="36">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GameNumber}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   FontSize="12" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="A色" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="黑" />
                                                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EngineAPlaysRed}" Value="True">
                                                            <Setter Property="Text" Value="紅" />
                                                            <Setter Property="Foreground" Value="#CC2222" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="結果" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="和棋" />
                                                    <Setter Property="Foreground" Value="#887733" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Outcome}"
                                                                     Value="EngineAWin">
                                                            <Setter Property="Text" Value="A 勝" />
                                                            <Setter Property="Foreground" Value="#336622" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Outcome}"
                                                                     Value="EngineBWin">
                                                            <Setter Property="Text" Value="B 勝" />
                                                            <Setter Property="Foreground" Value="#882222" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="步數" Width="48">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalMoves}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource InkBrush}"
                                                   FontSize="12" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="終止原因" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource InkMutedBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="—" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Reason}" Value="Checkmate">
                                                            <Setter Property="Text" Value="將殺" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Reason}" Value="Stalemate">
                                                            <Setter Property="Text" Value="困斃" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Reason}" Value="DrawByRepetition">
                                                            <Setter Property="Text" Value="重複局面" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Reason}" Value="DrawByNoCapture">
                                                            <Setter Property="Text" Value="無吃子" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Reason}" Value="DrawByInsufficientMaterial">
                                                            <Setter Property="Text" Value="棋子不足" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Reason}" Value="Resignation">
                                                            <Setter Property="Text" Value="認輸" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Reason}" Value="MaxMoves">
                                                            <Setter Property="Text" Value="步數上限" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
