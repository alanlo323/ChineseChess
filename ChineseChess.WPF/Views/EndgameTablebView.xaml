<UserControl x:Class="ChineseChess.WPF.Views.EndgameTablebView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EndgameTablebViewModel}"
             d:DesignHeight="560" d:DesignWidth="300">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="6">

            <!-- ── 子力組合選擇 ───────────────────────────────────── -->
            <TextBlock Text="子力組合" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <ComboBox ItemsSource="{Binding AvailableConfigurations}"
                      SelectedItem="{Binding SelectedConfiguration}"
                      DisplayMemberPath="DisplayName"
                      IsEnabled="{Binding IsNotGenerating}"
                      Margin="0,0,0,6"/>

            <!-- ── 操作按鈕列 ─────────────────────────────────────── -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="生成殘局庫"
                        Command="{Binding GenerateCommand}"
                        Padding="8,5" Margin="0,0,4,0"/>
                <Button Grid.Column="1"
                        Content="取消"
                        Command="{Binding CancelGenerationCommand}"
                        Padding="8,5"/>
            </Grid>

            <!-- ── 進度條 ─────────────────────────────────────────── -->
            <ProgressBar Value="{Binding GenerationProgress, Mode=OneWay}"
                         Minimum="0" Maximum="1"
                         Height="10" Margin="0,0,0,4"
                         Visibility="{Binding IsGenerating,
                             Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Text="{Binding GenerationStatusText}"
                       FontSize="11"
                       Foreground="#555"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <!-- ── 統計數字 ────────────────────────────────────────── -->
            <Border Background="#F0EAD6" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="總計" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="必勝" FontSize="10" Foreground="#B22222" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding WinCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" Foreground="#B22222" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="必負" FontSize="10" Foreground="#444" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LossCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="和棋" FontSize="10" Foreground="#2A6496" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DrawCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" Foreground="#2A6496" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 查詢當前局面 ──────────────────────────────────── -->
            <Separator Margin="0,0,0,6"/>
            <TextBlock Text="查詢當前棋盤局面" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Button Content="查詢當前局面"
                    Command="{Binding QueryCurrentCommand}"
                    HorizontalAlignment="Left"
                    Padding="10,5" Margin="0,0,0,6"/>

            <Border Background="#FFF8F0" BorderBrush="#DDBB99" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="0,0,0,4"
                    Visibility="{Binding HasTablebase,
                        Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding QueryResultText}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#8B3000"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding BestMoveText}"
                               FontSize="11" Foreground="#555"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasBestMoveText,
                                   Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- ── 匯出 / 匯入 ────────────────────────────────────── -->
            <Separator Margin="0,6,0,6"/>
            <UniformGrid Columns="2">
                <Button Content="匯出 FEN 文件..."
                        Command="{Binding ExportCommand}"
                        Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="匯入 FEN 文件..."
                        Command="{Binding ImportCommand}"
                        Padding="8,5"/>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
