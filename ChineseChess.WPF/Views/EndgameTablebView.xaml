<UserControl x:Class="ChineseChess.WPF.Views.EndgameTablebView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EndgameTablebViewModel}"
             d:DesignHeight="720" d:DesignWidth="300">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="6">

            <!-- ── 預設快選 ────────────────────────────────────────────── -->
            <TextBlock Text="子力組合" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableConfigurations}"
                          SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsNotGenerating}"
                          Margin="0,0,4,0"/>
                <Button Grid.Column="1"
                        Content="套用"
                        Command="{Binding ApplyPresetCommand}"
                        Padding="8,4"/>
            </Grid>

            <!-- ── 紅方棋子 ────────────────────────────────────────────── -->
            <TextBlock Text="紅方（不含帥）" FontWeight="SemiBold" Margin="0,2,0,2"/>
            <Border Background="#FFF8F0" CornerRadius="4" Padding="6,4" Margin="0,0,0,6">
                <ItemsControl ItemsSource="{Binding PieceSelector.RedPieces}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#B22222"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="−"
                                        Command="{Binding DecrementCommand}"
                                        Width="22" Height="22" FontSize="13"
                                        Padding="0" Margin="2,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Count}"
                                           Width="20"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="＋"
                                        Command="{Binding IncrementCommand}"
                                        Width="22" Height="22" FontSize="11"
                                        Padding="0" Margin="2,0"/>
                                <TextBlock Grid.Column="4"
                                           Text="{Binding Max, StringFormat=（最多{0}枚）}"
                                           FontSize="10" Foreground="#999"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── 黑方棋子 ────────────────────────────────────────────── -->
            <TextBlock Text="黑方（不含將）" FontWeight="SemiBold" Margin="0,2,0,2"/>
            <Border Background="#F0EAD6" CornerRadius="4" Padding="6,4" Margin="0,0,0,6">
                <ItemsControl ItemsSource="{Binding PieceSelector.BlackPieces}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="−"
                                        Command="{Binding DecrementCommand}"
                                        Width="22" Height="22" FontSize="13"
                                        Padding="0" Margin="2,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Count}"
                                           Width="20"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="＋"
                                        Command="{Binding IncrementCommand}"
                                        Width="22" Height="22" FontSize="11"
                                        Padding="0" Margin="2,0"/>
                                <TextBlock Grid.Column="4"
                                           Text="{Binding Max, StringFormat=（最多{0}枚）}"
                                           FontSize="10" Foreground="#999"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── 預計局面數 ─────────────────────────────────────────── -->
            <TextBlock Text="{Binding PieceSelector.EstimatedPositionsText}"
                       FontSize="11"
                       Foreground="{Binding PieceSelector.IsWarning,
                           Converter={StaticResource BoolToWarningColorConverter}}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,6"/>

            <!-- ── 操作按鈕 ────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="生成殘局庫"
                        Command="{Binding GenerateCommand}"
                        Padding="8,5" Margin="0,0,4,0"/>
                <Button Grid.Column="1"
                        Content="取消"
                        Command="{Binding CancelGenerationCommand}"
                        Padding="8,5"/>
            </Grid>
            <UniformGrid Columns="2" Margin="0,0,0,6">
                <Button Content="從當前局面生成"
                        Command="{Binding GenerateFromBoardCommand}"
                        Padding="8,5" Margin="0,0,4,0"
                        ToolTip="分析棋盤上的實際子力，自動生成對應殘局庫"/>
                <Button Content="同步步法至 TT"
                        Command="{Binding SyncToTTCommand}"
                        Padding="8,5"
                        ToolTip="將殘局庫的最佳著法寫入 AI 搜尋表，使 AI 自動走殘局庫步法"/>
            </UniformGrid>

            <!-- ── 進度條 ─────────────────────────────────────────────── -->
            <ProgressBar Value="{Binding GenerationProgress, Mode=OneWay}"
                         Minimum="0" Maximum="1"
                         Height="10" Margin="0,0,0,4"
                         Visibility="{Binding IsGenerating,
                             Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Text="{Binding GenerationStatusText}"
                       FontSize="11"
                       Foreground="#555"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <!-- ── 統計數字 ────────────────────────────────────────────── -->
            <Border Background="#F0EAD6" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="總計" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="必勝" FontSize="10" Foreground="#B22222" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding WinCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" Foreground="#B22222" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="必負" FontSize="10" Foreground="#444" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LossCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="和棋" FontSize="10" Foreground="#2A6496" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DrawCount, StringFormat={}{0:N0}}"
                                   FontWeight="Bold" Foreground="#2A6496" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 查詢當前局面 ──────────────────────────────────────── -->
            <Separator Margin="0,0,0,6"/>
            <TextBlock Text="查詢當前棋盤局面" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Button Content="查詢當前局面"
                    Command="{Binding QueryCurrentCommand}"
                    HorizontalAlignment="Left"
                    Padding="10,5" Margin="0,0,0,6"/>

            <Border Background="#FFF8F0" BorderBrush="#DDBB99" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="0,0,0,4"
                    Visibility="{Binding HasTablebase,
                        Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding QueryResultText}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#8B3000"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding BestMoveText}"
                               FontSize="11" Foreground="#555"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasBestMoveText,
                                   Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- ── 匯出 / 匯入 ────────────────────────────────────────── -->
            <Separator Margin="0,6,0,6"/>
            <UniformGrid Columns="2">
                <Button Content="匯出 FEN 文件..."
                        Command="{Binding ExportCommand}"
                        Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="匯入 FEN 文件..."
                        Command="{Binding ImportCommand}"
                        Padding="8,5"/>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
