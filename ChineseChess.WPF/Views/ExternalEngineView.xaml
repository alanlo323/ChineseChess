<UserControl x:Class="ChineseChess.WPF.Views.ExternalEngineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ExternalEngineViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,8">

            <!-- ─── 紅方外部引擎 ────────────────────────────────── -->
            <TextBlock Text="紅方引擎"
                       Style="{StaticResource SectionTitleStyle}"
                       Foreground="#CC2200"
                       Margin="0,0,0,6" />

            <CheckBox Content="使用外部引擎（取代內建引擎）"
                      IsChecked="{Binding UseRedExternalEngine}"
                      Foreground="{StaticResource InkBrush}"
                      Margin="0,0,0,6" />

            <!-- 協議選擇 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="協議："
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding EngineProtocols}"
                          SelectedItem="{Binding RedProtocol}"
                          Style="{StaticResource InputControlStyle}"
                          IsEnabled="{Binding UseRedExternalEngine}" />
            </Grid>

            <!-- 引擎路徑 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RedEnginePath, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding UseRedExternalEngine}"
                         Margin="0,0,6,0" />
                <Button Grid.Column="1"
                        Content="瀏覽..."
                        Command="{Binding BrowseRedEngineCommand}"
                        Style="{StaticResource CompactButtonStyle}"
                        Width="50"
                        IsEnabled="{Binding UseRedExternalEngine}" />
            </Grid>

            <!-- 套用按鈕 + 狀態 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="套用"
                        Command="{Binding ApplyRedEngineCommand}"
                        Style="{StaticResource CompactButtonStyle}"
                        Width="50"
                        Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding RedEngineStatus}"
                           Style="{StaticResource StatusTextStyle}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </Grid>

            <!-- ─── 紅方 Pikafish 進階設定 ──────────────────────── -->
            <GroupBox Header="Pikafish 進階設定"
                      Visibility="{Binding RedIsPikafish, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="0,6,0,0">
                <StackPanel Margin="4,4,4,4">
                    <!-- Clear Hash -->
                    <Button Content="清除哈希（Clear Hash）"
                            Command="{Binding ClearRedHashCommand}"
                            Style="{StaticResource CompactButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,6" />

                    <!-- MultiPV -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MultiPV（1-500）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RedMultiPv, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- Skill Level -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="技能等級（0-20）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RedSkillLevel, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- UCI_LimitStrength -->
                    <CheckBox Content="限制強度（UCI_LimitStrength）"
                              IsChecked="{Binding RedUciLimitStrength}"
                              Foreground="{StaticResource InkBrush}"
                              Margin="0,0,0,4" />

                    <!-- UCI_Elo -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ELO（1280-3133）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RedUciElo, UpdateSourceTrigger=LostFocus}"
                                 IsEnabled="{Binding RedUciEloEnabled}" />
                    </Grid>

                    <!-- Sixty Move Rule -->
                    <CheckBox Content="六十步和棋規則"
                              IsChecked="{Binding RedSixtyMoveRule}"
                              Foreground="{StaticResource InkBrush}"
                              Margin="0,0,0,4" />

                    <!-- Rule60MaxPly -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="六十步最大半步（1-150）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RedRule60MaxPly, UpdateSourceTrigger=LostFocus}"
                                 IsEnabled="{Binding RedRule60MaxPlyEnabled}" />
                    </Grid>

                    <!-- MateThreatDepth -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="將殺威脅深度（0-10）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RedMateThreatDepth, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- ScoreType -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="評分顯示方式："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ScoreTypes}"
                                  SelectedItem="{Binding RedScoreType}"
                                  Style="{StaticResource InputControlStyle}" />
                    </Grid>

                    <!-- LU_Output -->
                    <CheckBox Content="LU 輸出格式（LU_Output）"
                              IsChecked="{Binding RedLuOutput}"
                              Foreground="{StaticResource InkBrush}"
                              Margin="0,0,0,4" />

                    <!-- DrawRule -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="和棋規則："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding DrawRules}"
                                  SelectedItem="{Binding RedDrawRule}"
                                  Style="{StaticResource InputControlStyle}" />
                    </Grid>

                    <!-- EvalFile -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="EvalFile："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RedEvalFile, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,6,0" />
                        <Button Grid.Column="2"
                                Content="瀏覽..."
                                Command="{Binding BrowseRedEvalFileCommand}"
                                Style="{StaticResource CompactButtonStyle}"
                                Width="50" />
                    </Grid>

                    <!-- 套用 Pikafish 設定 -->
                    <Button Content="套用 Pikafish 設定"
                            Command="{Binding ApplyRedPikafishCommand}"
                            Style="{StaticResource CompactButtonStyle}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </GroupBox>

            <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />

            <!-- ─── 黑方外部引擎 ────────────────────────────────── -->
            <TextBlock Text="黑方引擎"
                       Style="{StaticResource SectionTitleStyle}"
                       Foreground="#222222"
                       Margin="0,0,0,6" />

            <CheckBox Content="使用外部引擎（取代內建引擎）"
                      IsChecked="{Binding UseBlackExternalEngine}"
                      Foreground="{StaticResource InkBrush}"
                      Margin="0,0,0,6" />

            <!-- 協議選擇 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="協議："
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding EngineProtocols}"
                          SelectedItem="{Binding BlackProtocol}"
                          Style="{StaticResource InputControlStyle}"
                          IsEnabled="{Binding UseBlackExternalEngine}" />
            </Grid>

            <!-- 引擎路徑 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding BlackEnginePath, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding UseBlackExternalEngine}"
                         Margin="0,0,6,0" />
                <Button Grid.Column="1"
                        Content="瀏覽..."
                        Command="{Binding BrowseBlackEngineCommand}"
                        Style="{StaticResource CompactButtonStyle}"
                        Width="50"
                        IsEnabled="{Binding UseBlackExternalEngine}" />
            </Grid>

            <!-- 套用按鈕 + 狀態 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="套用"
                        Command="{Binding ApplyBlackEngineCommand}"
                        Style="{StaticResource CompactButtonStyle}"
                        Width="50"
                        Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BlackEngineStatus}"
                           Style="{StaticResource StatusTextStyle}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </Grid>

            <!-- ─── 黑方 Pikafish 進階設定 ──────────────────────── -->
            <GroupBox Header="Pikafish 進階設定"
                      Visibility="{Binding BlackIsPikafish, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="0,6,0,0">
                <StackPanel Margin="4,4,4,4">
                    <!-- Clear Hash -->
                    <Button Content="清除哈希（Clear Hash）"
                            Command="{Binding ClearBlackHashCommand}"
                            Style="{StaticResource CompactButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,6" />

                    <!-- MultiPV -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MultiPV（1-500）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding BlackMultiPv, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- Skill Level -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="技能等級（0-20）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding BlackSkillLevel, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- UCI_LimitStrength -->
                    <CheckBox Content="限制強度（UCI_LimitStrength）"
                              IsChecked="{Binding BlackUciLimitStrength}"
                              Foreground="{StaticResource InkBrush}"
                              Margin="0,0,0,4" />

                    <!-- UCI_Elo -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ELO（1280-3133）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding BlackUciElo, UpdateSourceTrigger=LostFocus}"
                                 IsEnabled="{Binding BlackUciEloEnabled}" />
                    </Grid>

                    <!-- Sixty Move Rule -->
                    <CheckBox Content="六十步和棋規則"
                              IsChecked="{Binding BlackSixtyMoveRule}"
                              Foreground="{StaticResource InkBrush}"
                              Margin="0,0,0,4" />

                    <!-- Rule60MaxPly -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="六十步最大半步（1-150）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding BlackRule60MaxPly, UpdateSourceTrigger=LostFocus}"
                                 IsEnabled="{Binding BlackRule60MaxPlyEnabled}" />
                    </Grid>

                    <!-- MateThreatDepth -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="將殺威脅深度（0-10）："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding BlackMateThreatDepth, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- ScoreType -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="評分顯示方式："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ScoreTypes}"
                                  SelectedItem="{Binding BlackScoreType}"
                                  Style="{StaticResource InputControlStyle}" />
                    </Grid>

                    <!-- LU_Output -->
                    <CheckBox Content="LU 輸出格式（LU_Output）"
                              IsChecked="{Binding BlackLuOutput}"
                              Foreground="{StaticResource InkBrush}"
                              Margin="0,0,0,4" />

                    <!-- DrawRule -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="和棋規則："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding DrawRules}"
                                  SelectedItem="{Binding BlackDrawRule}"
                                  Style="{StaticResource InputControlStyle}" />
                    </Grid>

                    <!-- EvalFile -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="EvalFile："
                                   Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding BlackEvalFile, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,6,0" />
                        <Button Grid.Column="2"
                                Content="瀏覽..."
                                Command="{Binding BrowseBlackEvalFileCommand}"
                                Style="{StaticResource CompactButtonStyle}"
                                Width="50" />
                    </Grid>

                    <!-- 套用 Pikafish 設定 -->
                    <Button Content="套用 Pikafish 設定"
                            Command="{Binding ApplyBlackPikafishCommand}"
                            Style="{StaticResource CompactButtonStyle}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </GroupBox>

            <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />

            <!-- ─── 雙協議伺服器 ───────────────────────────────── -->
            <TextBlock Text="UCI / UCCI 伺服器"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />
            <TextBlock Text="開啟後可讓外部棋類管理軟體（如 Arena）連線至此程式的內建引擎。"
                       Style="{StaticResource FormLabelStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />

            <!-- 埠號設定 -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TCP 埠號："
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsServerStopped}" />
            </Grid>

            <!-- 啟動 / 停止按鈕 -->
            <UniformGrid Columns="2" Margin="0,0,0,6">
                <Button Content="啟動伺服器"
                        Command="{Binding StartServerCommand}"
                        Style="{StaticResource CompactButtonStyle}"
                        Margin="0,0,6,0" />
                <Button Content="停止伺服器"
                        Command="{Binding StopServerCommand}"
                        Style="{StaticResource CompactButtonStyle}" />
            </UniformGrid>

            <!-- 伺服器狀態 -->
            <TextBlock Text="{Binding ServerStatus}"
                       Style="{StaticResource StatusTextStyle}"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
