<UserControl x:Class="ChineseChess.WPF.Views.ExternalEngineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             xmlns:views="clr-namespace:ChineseChess.WPF.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ExternalEngineViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,8">

            <!-- ─── 外部引擎管理 ──────────────────────────────── -->
            <TextBlock Text="外部引擎管理"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />
            <Border BorderBrush="{StaticResource WoodDarkBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="{StaticResource PanelBackgroundBrush}"
                    Padding="8,6"
                    Margin="0,0,0,8">
                <views:LoadedEngineListView DataContext="{Binding LoadedEngineList}" />
            </Border>

            <Separator Margin="0,0,0,8" />

            <!-- ─── 雙協議伺服器 ───────────────────────────────── -->
            <TextBlock Text="UCI / UCCI 伺服器"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />
            <TextBlock Text="開啟後可讓外部棋類管理軟體（如 Arena）連線至此程式的內建引擎。"
                       Style="{StaticResource FormLabelStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />

            <!-- 埠號設定 -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TCP 埠號："
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsServerStopped}" />
            </Grid>

            <!-- 啟動 / 停止按鈕 -->
            <UniformGrid Columns="2" Margin="0,0,0,6">
                <Button Content="啟動伺服器"
                        Command="{Binding StartServerCommand}"
                        Style="{StaticResource CompactButtonStyle}"
                        Margin="0,0,6,0" />
                <Button Content="停止伺服器"
                        Command="{Binding StopServerCommand}"
                        Style="{StaticResource CompactButtonStyle}" />
            </UniformGrid>

            <!-- 伺服器狀態 -->
            <TextBlock Text="{Binding ServerStatus}"
                       Style="{StaticResource StatusTextStyle}"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
