<UserControl x:Class="ChineseChess.WPF.Views.NnueTrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:NnueTrainingViewModel}">

    <GroupBox Header="本機訓練"
              Margin="0,8,0,0"
              Padding="8">
        <StackPanel>

            <!-- ─── 訓練設定 ─────────────────────────────────────────── -->
            <TextBlock Text="訓練設定"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,6" />

            <!-- 訓練模式選擇 -->
            <TextBlock Text="訓練模式："
                       Style="{StaticResource FormLabelStyle}"
                       Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton Content="從檔案匯入"
                             IsChecked="{Binding IsFromFileMode}"
                             GroupName="TrainingMode"
                             Margin="0,0,12,0"
                             ToolTip="從 .plain 格式的靜態對局資料檔訓練" />
                <RadioButton Content="NNUE 對戰手工評估"
                             IsChecked="{Binding IsVsHandcraftedMode}"
                             GroupName="TrainingMode"
                             Margin="0,0,12,0"
                             ToolTip="用 NNUE 對戰 HandcraftedEvaluator 動態生成訓練資料" />
                <RadioButton Content="自我對戰"
                             IsChecked="{Binding IsSelfPlayMode}"
                             GroupName="TrainingMode"
                             ToolTip="兩方皆使用當前 NNUE 自我對弈生成訓練資料" />
            </StackPanel>

            <!-- 訓練資料路徑（FromFile 模式） -->
            <StackPanel Visibility="{Binding IsFromFileMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="訓練資料（.plain）："
                           Style="{StaticResource FormLabelStyle}"
                           Margin="0,0,0,2" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding TrainingDataPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="訓練資料檔路徑（.plain 格式：FEN | Score | Result）" />
                    <Button Grid.Column="1"
                            Content="瀏覽…"
                            Command="{Binding BrowseDataFileCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="4,0,0,0" />
                </Grid>
            </StackPanel>

            <!-- 生成設定（VsHandcrafted / SelfPlay 模式） -->
            <StackPanel Visibility="{Binding IsGeneratorMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="生成局數/Epoch"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,0,0,2" />
                        <TextBox Text="{Binding GameCount, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="每個 Epoch 生成的對局局數（建議 20~100）" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="搜尋深度"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,0,0,2" />
                        <TextBox Text="{Binding SearchDepth, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="生成對局時每步的搜尋深度（建議 3~6）" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="每步時限(ms)"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,0,0,2" />
                        <TextBox Text="{Binding SearchTimeLimitMs, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="每步搜尋時間上限（毫秒）" />
                    </StackPanel>
                </Grid>

                <!-- 隨機開局（SelfPlay 模式） -->
                <Grid Margin="0,0,0,8"
                      Visibility="{Binding IsSelfPlayMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="隨機開局步數"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,0,0,2" />
                        <TextBox Text="{Binding RandomOpeningMoves, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="前 N 步隨機走棋，增加對局多樣性（建議 4~12）" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 輸出模型路徑 -->
            <TextBlock Text="輸出模型（.nnue）："
                       Style="{StaticResource FormLabelStyle}"
                       Margin="0,0,0,2" />
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding OutputModelPath, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="訓練完成後自動儲存的 .nnue 模型路徑" />
                <Button Grid.Column="1"
                        Content="儲存為…"
                        Command="{Binding BrowseOutputFileCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="4,0,0,0" />
            </Grid>

            <!-- 超參數（三欄） -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="學習率"
                               Style="{StaticResource FormLabelStyle}"
                               Margin="0,0,0,2" />
                    <TextBox Text="{Binding LearningRateText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Adam 優化器初始學習率（預設 0.001）" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="批次大小"
                               Style="{StaticResource FormLabelStyle}"
                               Margin="0,0,0,2" />
                    <TextBox Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="每批次樣本數（預設 256）" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Epoch 數"
                               Style="{StaticResource FormLabelStyle}"
                               Margin="0,0,0,2" />
                    <TextBox Text="{Binding EpochCount, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="訓練 epoch 總數（預設 20）" />
                </StackPanel>
            </Grid>

            <!-- ─── 控制按鈕 ─────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                <Button Content="開始訓練"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,6,0" />
                <Button Content="{Binding PauseResumeLabel}"
                        Command="{Binding PauseResumeCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,6,0" />
                <Button Content="停止"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,6,0" />
                <Button Content="立即匯出"
                        Command="{Binding ExportNowCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        ToolTip="將當前網路量化匯出為 .nnue（不需等待訓練完成）" />
            </StackPanel>

            <!-- ─── 生成進度區（Generator 模式時顯示）────────────────────── -->
            <StackPanel Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,0,8">
                <TextBlock Text="生成對局中…"
                           Style="{StaticResource FormLabelStyle}"
                           Margin="0,0,0,2" />
                <ProgressBar Maximum="{Binding TotalGamesTarget}"
                             Value="{Binding GeneratedGames, Mode=OneWay}"
                             Height="6"
                             Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource InkBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="已完成 {0}/{1} 局，共收集 {2} 個局面">
                                <Binding Path="GeneratedGames" />
                                <Binding Path="TotalGamesTarget" />
                                <Binding Path="CollectedPositions" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- ─── 訓練進度區 ────────────────────────────────────────────── -->
            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                         Maximum="100"
                         Height="8"
                         Margin="0,0,0,4" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 左欄 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Epoch："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Foreground="{StaticResource InkBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="CurrentEpoch" />
                                <Binding Path="TotalEpochs" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Loss："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Text="{Binding CurrentLoss, StringFormat={}{0:F4}}"
                               Foreground="{StaticResource InkBrush}" />
                </StackPanel>

                <!-- 右欄 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="最佳："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Foreground="{StaticResource InkBrush}">
                        <TextBlock.Text>
                            <Binding Path="BestLoss" StringFormat="{}{0:F4}" />
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="預計剩餘："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Text="{Binding EtaText}"
                               Foreground="{StaticResource InkBrush}" />
                </StackPanel>
            </Grid>

            <!-- ─── 狀態與日誌 ─────────────────────────────────────────── -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource InkBrush}"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />

            <ListBox ItemsSource="{Binding LogLines}"
                     Height="130"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     FontSize="11"
                     FontFamily="Consolas"
                     Background="Transparent"
                     BorderThickness="1">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="2,1" />
                        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>
    </GroupBox>

</UserControl>
