<UserControl x:Class="ChineseChess.WPF.Views.LoadedNnueModelListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LoadedNnueModelListViewModel}">

    <StackPanel>

        <!-- ─── 新增模型按鈕列 ──────────────────────────────── -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="新增模型..."
                    Command="{Binding AddModelCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,8,0" />

            <TextBlock Grid.Column="1"
                       Text="{Binding AddStatusMessage}"
                       Style="{StaticResource StatusTextStyle}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </Grid>

        <!-- ─── 模型列表 ─────────────────────────────────────── -->
        <ListBox ItemsSource="{Binding Models}"
                 SelectedItem="{Binding SelectedModel}"
                 MaxHeight="180"
                 BorderThickness="1"
                 BorderBrush="{StaticResource WoodDarkBrush}"
                 Background="{StaticResource PanelBackgroundBrush}"
                 Margin="0,0,0,6">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:LoadedNnueModelItemViewModel}">
                    <Grid Margin="2,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayName}"
                                   Foreground="{StaticResource InkBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Content="移除"
                                Command="{Binding RemoveCommand}"
                                Style="{StaticResource CompactButtonStyle}"
                                Width="40"
                                Margin="6,0,0,0" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ─── 詳細資訊面板（選取模型時顯示）──────────────── -->
        <Border BorderBrush="{StaticResource WoodDarkBrush}"
                BorderThickness="1"
                CornerRadius="3"
                Background="{StaticResource PanelBackgroundBrush}"
                Padding="8,6"
                Visibility="{Binding SelectedModel.ModelId, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="模型詳情"
                           Style="{StaticResource SectionTitleStyle}"
                           FontSize="12"
                           Margin="0,0,0,4" />

                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="路徑："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedModel.FilePath}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SelectedModel.FilePath}" />
                </Grid>

                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="描述："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedModel.Description}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>

                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="大小："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedModel.FormattedFileSize}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>

                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Elo："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedModel.EloText}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="載入時間："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedModel.LoadedAt, StringFormat=yyyy-MM-dd HH:mm}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
