<UserControl x:Class="ChineseChess.WPF.Views.ChessBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChessBoardViewModel}"
             Height="616" Width="540">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BoardHoverBrush" Color="#B58F5F" />
        <SolidColorBrush x:Key="BoardPressedBrush" Color="#8D6A3A" />
        <SolidColorBrush x:Key="SelectedGlowBrush" Color="#F2E08E" />

        <Style x:Key="SquareButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SquareFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SquareFrame" Property="Background" Value="Transparent" />
                                <Setter TargetName="SquareFrame" Property="BorderBrush" Value="{StaticResource BoardHoverBrush}" />
                                <Setter TargetName="SquareFrame" Property="BorderThickness" Value="1.2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SquareFrame" Property="Background" Value="{StaticResource BoardPressedBrush}" />
                                <Setter TargetName="SquareFrame" Property="BorderBrush" Value="{StaticResource BoardPressedBrush}" />
                                <Setter TargetName="SquareFrame" Property="BorderThickness" Value="1.2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SquareFrame" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PieceTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource ChineseClassicFont}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Width="540" Height="616">
        <Border Background="{StaticResource BoardOuterBrush}"
                BorderBrush="{StaticResource BoardOuterBrush}"
                BorderThickness="0"
                CornerRadius="10">
            <Grid Margin="30,28">
                <Border Background="{StaticResource BoardPatternBrush}" CornerRadius="2" />

                <Canvas IsHitTestVisible="False">
                    <Rectangle Width="480"
                               Height="560"
                               Stroke="{StaticResource BoardLineBrush}"
                               StrokeThickness="2.8"
                               RadiusX="2"
                               RadiusY="2"
                               Opacity="0.95" />

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Miter">
                        <Path.Data>
                            <PathGeometry Figures="
M0,0 L0,280 M0,336 L0,560
M60,0 L60,280 M60,336 L60,560
M120,0 L120,280 M120,336 L120,560
M180,0 L180,280 M180,336 L180,560
M240,0 L240,280 M240,336 L240,560
M300,0 L300,280 M300,336 L300,560
M360,0 L360,280 M360,336 L360,560
M420,0 L420,280 M420,336 L420,560
M480,0 L480,280 M480,336 L480,560" />
                        </Path.Data>
                    </Path>

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Miter">
                        <Path.Data>
                            <PathGeometry Figures="
M0,0 L480,0
M0,56 L480,56
M0,112 L480,112
M0,168 L480,168
M0,224 L480,224
M0,336 L480,336
M0,392 L480,392
M0,448 L480,448
M0,504 L480,504
M0,560 L480,560" />
                        </Path.Data>
                    </Path>

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="2.2">
                        <Path.Data>
                            <PathGeometry Figures="
M180,0 L300,112
M300,0 L180,112
M180,448 L300,560
M300,448 L180,560" />
                        </Path.Data>
                    </Path>

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square">
                        <Path.Data>
                            <PathGeometry Figures="
M72,132 L82,132 M82,132 L82,122
M98,132 L108,132 M98,132 L98,122
M72,148 L82,148 M82,148 L82,158
M98,148 L108,148 M98,148 L98,158

M432,132 L442,132 M442,132 L442,122
M458,132 L468,132 M458,132 L458,122
M432,148 L442,148 M442,148 L442,158
M458,148 L468,148 M458,148 L458,158

M72,412 L82,412 M82,412 L82,402
M98,412 L108,412 M98,412 L98,402
M72,428 L82,428 M82,428 L82,438
M98,428 L108,428 M98,428 L98,438

M432,412 L442,412 M442,412 L442,402
M458,412 L468,412 M458,412 L458,402
M432,428 L442,428 M442,428 L442,438
M458,428 L468,428 M458,428 L458,438

M38,188 L48,188 M38,188 L38,178
M38,204 L48,204 M38,204 L38,214
M132,188 L142,188 M142,188 L142,178
M158,188 L168,188 M158,188 L158,178
M132,204 L142,204 M142,204 L142,214
M158,204 L168,204 M158,204 L158,214
M252,188 L262,188 M262,188 L262,178
M278,188 L288,188 M278,188 L278,178
M252,204 L262,204 M262,204 L262,214
M278,204 L288,204 M278,204 L278,214
M372,188 L382,188 M382,188 L382,178
M398,188 L408,188 M398,188 L398,178
M372,204 L382,204 M382,204 L382,214
M398,204 L408,204 M398,204 L398,214

M38,356 L48,356 M38,356 L38,346
M38,372 L48,372 M38,372 L38,382
M132,356 L142,356 M142,356 L142,346
M158,356 L168,356 M158,356 L158,346
M132,372 L142,372 M142,372 L142,382
M158,372 L168,372 M158,372 L158,382
M252,356 L262,356 M262,356 L262,346
M278,356 L288,356 M278,356 L278,346
M252,372 L262,372 M262,372 L262,382
M278,372 L288,372 M278,372 L278,382
M372,356 L382,356 M382,356 L382,346
M398,356 L408,356 M398,356 L398,346
M372,372 L382,372 M382,372 L382,382
M398,372 L408,372 M398,372 L398,382" />
                        </Path.Data>
                    </Path>

                    <TextBlock Text="楚 河"
                               FontFamily="{StaticResource ChineseClassicFont}"
                               FontWeight="SemiBold"
                               FontSize="22"
                               Foreground="{StaticResource BoardRiverTextBrush}"
                               Opacity="0.95"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-2" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="1.5" ShadowDepth="0" Opacity="0.2" />
                        </TextBlock.Effect>
                        <TextBlock.Margin>
                            <Thickness>160,270,0,0</Thickness>
                        </TextBlock.Margin>
                    </TextBlock>

                    <TextBlock Text="漢 界"
                               FontFamily="{StaticResource ChineseClassicFont}"
                               FontSize="22"
                               FontWeight="Semibold"
                               Foreground="{StaticResource BoardRiverTextBrush}"
                               Opacity="0.95"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="2" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="1.5" ShadowDepth="0" Opacity="0.2" />
                        </TextBlock.Effect>
                        <TextBlock.Margin>
                            <Thickness>225,270,0,0</Thickness>
                        </TextBlock.Margin>
                    </TextBlock>
                </Canvas>

                <ItemsControl ItemsSource="{Binding Squares}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="480" Height="560" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding HitBoxLeft}" />
                            <Setter Property="Canvas.Top" Value="{Binding HitBoxTop}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SquareButtonStyle}"
                                    Width="60"
                                    Height="56"
                                    Command="{Binding DataContext.SquareClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Border x:Name="SelectionRing"
                                            Width="42"
                                            Height="42"
                                            BorderBrush="{StaticResource SelectedGlowBrush}"
                                            BorderThickness="3"
                                            CornerRadius="21"
                                            Opacity="0.85"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border x:Name="LastMoveRing"
                                    Width="46"
                                    Height="46"
                                    BorderBrush="{StaticResource LastMoveBrush}"
                                    BorderThickness="2"
                                    CornerRadius="23"
                                    Opacity="0.65"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsLastMove, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border x:Name="HintFromRing"
                                            Width="44"
                                            Height="44"
                                            BorderBrush="{StaticResource HintFromBrush}"
                                            BorderThickness="3"
                                            CornerRadius="22"
                                            Opacity="0.9"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsHintFrom, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Border x:Name="HintToRing"
                                            Width="46"
                                            Height="46"
                                            BorderBrush="{StaticResource HintToBrush}"
                                            BorderThickness="2"
                                            CornerRadius="23"
                                            Opacity="0.85"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsHintTo, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Ellipse Width="14"
                                             Height="14"
                                             Fill="{StaticResource MoveHintBrush}"
                                             Opacity="0.75"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsValidMove, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Ellipse Width="18"
                                             Height="18"
                                             Fill="{StaticResource HintToBrush}"
                                             Opacity="0.8"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsHintTo, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <TextBlock Text="{Binding Piece, Converter={StaticResource PieceTextConverter}}"
                                               Foreground="{Binding Piece.Color, Converter={StaticResource ColorConverter}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="{StaticResource ChineseClassicFont}" />
                                                <Setter Property="FontSize" Value="30" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="TextAlignment" Value="Center" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="3"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.35"
                                                                          Color="#000000" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Piece.IsNone}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
