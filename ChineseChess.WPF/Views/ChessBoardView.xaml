<UserControl x:Class="ChineseChess.WPF.Views.ChessBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             xmlns:enums="clr-namespace:ChineseChess.Domain.Enums;assembly=ChineseChess.Domain"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChessBoardViewModel}"
             Height="560" Width="540">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BoardHoverBrush" Color="#B58F5F" />
        <SolidColorBrush x:Key="BoardPressedBrush" Color="#8D6A3A" />

        <Style x:Key="SquareButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SquareFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SquareFrame" Property="Background" Value="Transparent" />
                                <Setter TargetName="SquareFrame" Property="BorderBrush" Value="{StaticResource BoardHoverBrush}" />
                                <Setter TargetName="SquareFrame" Property="BorderThickness" Value="1.2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SquareFrame" Property="Background" Value="{StaticResource BoardPressedBrush}" />
                                <Setter TargetName="SquareFrame" Property="BorderBrush" Value="{StaticResource BoardPressedBrush}" />
                                <Setter TargetName="SquareFrame" Property="BorderThickness" Value="1.2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SquareFrame" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.08" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.08" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.93" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.93" Duration="0:0:0.07" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.08" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.08" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PieceTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource ChineseClassicFont}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Width="540" Height="560">
        <Border Background="{StaticResource BoardOuterBrush}"
                BorderBrush="{StaticResource BoardOuterBrush}"
                BorderThickness="0"
                CornerRadius="10">
            <Grid Margin="30,28">
                <Border Background="{StaticResource BoardPatternBrush}" CornerRadius="2" />

                <Canvas IsHitTestVisible="False">
                    <Rectangle Width="480"
                               Height="504"
                               Stroke="{StaticResource BoardLineBrush}"
                               StrokeThickness="2.8"
                               RadiusX="2"
                               RadiusY="2"
                               Opacity="0.95" />

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Miter">
                        <Path.Data>
                            <PathGeometry Figures="
M0,0 L0,224 M0,280 L0,504
M60,0 L60,224 M60,280 L60,504
M120,0 L120,224 M120,280 L120,504
M180,0 L180,224 M180,280 L180,504
M240,0 L240,224 M240,280 L240,504
M300,0 L300,224 M300,280 L300,504
M360,0 L360,224 M360,280 L360,504
M420,0 L420,224 M420,280 L420,504
M480,0 L480,224 M480,280 L480,504" />
                        </Path.Data>
                    </Path>

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Miter">
                        <Path.Data>
                            <PathGeometry Figures="
M0,0 L480,0
M0,56 L480,56
M0,112 L480,112
M0,168 L480,168
M0,224 L480,224
M0,280 L480,280
M0,336 L480,336
M0,392 L480,392
M0,448 L480,448
M0,504 L480,504" />
                        </Path.Data>
                    </Path>

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="2.2">
                        <Path.Data>
                            <PathGeometry Figures="
M180,0 L300,112
M300,0 L180,112
M180,392 L300,504
M300,392 L180,504" />
                        </Path.Data>
                    </Path>

                    <Path Stroke="{StaticResource BoardGridBrush}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square">
                        <Path.Data>
                            <PathGeometry Figures="
M40,102 L50,102 M50,102 L50,92
M70,102 L80,102 M70,102 L70,92
M40,122 L50,122 M50,122 L50,132
M70,122 L80,122 M70,122 L70,132

M400,102 L410,102 M410,102 L410,92
M430,102 L440,102 M430,102 L430,92
M400,122 L410,122 M410,122 L410,132
M430,122 L440,122 M430,122 L430,132

M40,382 L50,382 M50,382 L50,372
M70,382 L80,382 M70,382 L70,372
M40,402 L50,402 M50,402 L50,412
M70,402 L80,402 M70,402 L70,412

M400,382 L410,382 M410,382 L410,372
M430,382 L440,382 M430,382 L430,372
M400,402 L410,402 M410,402 L410,412
M430,402 L440,402 M430,402 L430,412

M10,158 L20,158 M10,158 L10,148
M10,178 L20,178 M10,178 L10,188
M100,158 L110,158 M110,158 L110,148
M130,158 L140,158 M130,158 L130,148
M100,178 L110,178 M110,178 L110,188
M130,178 L140,178 M130,178 L130,188
M220,158 L230,158 M230,158 L230,148
M250,158 L260,158 M250,158 L250,148
M220,178 L230,178 M230,178 L230,188
M250,178 L260,178 M250,178 L250,188
M340,158 L350,158 M350,158 L350,148
M370,158 L380,158 M370,158 L370,148
M340,178 L350,178 M350,178 L350,188
M370,178 L380,178 M370,178 L370,188
M460,158 L470,158 M470,158 L470,148
M460,178 L470,178 M470,178 L470,188

M10,326 L20,326 M10,326 L10,316
M10,346 L20,346 M10,346 L10,356
M100,326 L110,326 M110,326 L110,316
M130,326 L140,326 M130,326 L130,316
M100,346 L110,346 M110,346 L110,356
M130,346 L140,346 M130,346 L130,356
M220,326 L230,326 M230,326 L230,316
M250,326 L260,326 M250,326 L250,316
M220,346 L230,346 M230,346 L230,356
M250,346 L260,346 M250,346 L250,356
M340,326 L350,326 M350,326 L350,316
M370,326 L380,326 M370,326 L370,316
M340,346 L350,346 M350,346 L350,356
M370,346 L380,346 M370,346 L370,356
M460,326 L470,326 M470,326 L470,316
M460,346 L470,346 M470,346 L470,356" />
                        </Path.Data>
                    </Path>

                    <TextBlock Text="楚  河"
                               FontFamily="{StaticResource ChineseClassicFont}"
                               FontWeight="SemiBold"
                               FontSize="26"
                               Foreground="{StaticResource BoardRiverTextBrush}"
                               Opacity="0.95"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-2" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.2" />
                        </TextBlock.Effect>
                        <TextBlock.Margin>
                            <Thickness>148,232,0,0</Thickness>
                        </TextBlock.Margin>
                    </TextBlock>

                    <TextBlock Text="漢  界"
                               FontFamily="{StaticResource ChineseClassicFont}"
                               FontSize="26"
                               FontWeight="Semibold"
                               Foreground="{StaticResource BoardRiverTextBrush}"
                               Opacity="0.95"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="2" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.2" />
                        </TextBlock.Effect>
                        <TextBlock.Margin>
                            <Thickness>250,232,0,0</Thickness>
                        </TextBlock.Margin>
                    </TextBlock>
                </Canvas>

                <ItemsControl ItemsSource="{Binding Squares}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="480" Height="504" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding HitBoxLeft}" />
                            <Setter Property="Canvas.Top" Value="{Binding HitBoxTop}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SquareButtonStyle}"
                                    Width="60"
                                    Height="56"
                                    Command="{Binding DataContext.SquareClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.InputBindings>
                                    <MouseBinding MouseAction="RightClick"
                                                  Command="{Binding DataContext.SquareRightClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" />
                                </Button.InputBindings>
                                <Grid>
                                    <Border x:Name="SelectionRing"
                                            Width="42"
                                            Height="42"
                                            BorderBrush="{StaticResource SelectedGlowBrush}"
                                            BorderThickness="3"
                                            CornerRadius="21"
                                            Opacity="0.85"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <!-- 上一步起點：淡色填充圓（空格可見） -->
                            <Ellipse x:Name="LastMoveFromDot"
                                     Width="20" Height="20"
                                     Fill="{StaticResource LastMoveBrush}"
                                     Opacity="0.75"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsLastMoveFrom, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Border x:Name="HintToRing"
                                            Width="46"
                                            Height="46"
                                            BorderBrush="{StaticResource HintToBrush}"
                                            BorderThickness="2"
                                            CornerRadius="23"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsHintTo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- 最終結果：高亮度 -->
                                                <Setter Property="Opacity" Value="0.85" />
                                                <Style.Triggers>
                                                    <!-- 搜尋中待定：降低不透明度以示區分 -->
                                                    <DataTrigger Binding="{Binding IsHintPending}" Value="True">
                                                        <Setter Property="Opacity" Value="0.4" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- 普通提示：虛影棋子（落點顯示移動棋子，半透明） -->
                                    <Grid Width="46" Height="46"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0.55"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="7"
                                          Visibility="{Binding HasHintGhostPiece, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Ellipse Width="46" Height="46">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource RedPieceDiscBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HintGhostPiece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Fill" Value="{StaticResource BlackPieceDiscBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Ellipse Width="46" Height="46" Fill="Transparent">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Stroke" Value="{StaticResource RedPieceRingBrush}" />
                                                    <Setter Property="StrokeThickness" Value="2.5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HintGhostPiece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Stroke" Value="{StaticResource BlackPieceRingBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding HintGhostPiece, Converter={StaticResource PieceTextConverter}}"
                                                   FontFamily="{StaticResource ChineseClassicFont}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource RedPieceTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HintGhostPiece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Foreground" Value="{StaticResource BlackPieceTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <Ellipse Width="14"
                                             Height="14"
                                             Fill="{StaticResource MoveHintBrush}"
                                             Opacity="0.75"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsValidMove}" Value="True" />
                                                            <Condition Binding="{Binding Piece.IsNone}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <Border Width="46"
                                            Height="46"
                                            BorderBrush="{StaticResource HintToBrush}"
                                            BorderThickness="2.5"
                                            CornerRadius="23"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Panel.ZIndex="10"
                                            IsHitTestVisible="False"
                                            Opacity="0.85">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsValidMove}" Value="True" />
                                                            <Condition Binding="{Binding Piece.IsNone}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Ellipse Width="18"
                                             Height="18"
                                             Fill="{StaticResource HintToBrush}"
                                             Opacity="0.8"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsHintTo, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <!-- 棋子圓盤 -->
                                    <Grid Width="46" Height="46"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Piece.IsNone}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <Border x:Name="HintFromPieceRing"
                                                Width="46"
                                                Height="46"
                                                BorderBrush="{StaticResource HintFromBrush}"
                                                BorderThickness="3"
                                                CornerRadius="23"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsHitTestVisible="False"
                                                Panel.ZIndex="20"
                                                Visibility="{Binding IsHintFrom, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <!-- 最終結果：高亮度 -->
                                                    <Setter Property="Opacity" Value="0.95" />
                                                    <Style.Triggers>
                                                        <!-- 搜尋中待定：降低不透明度以示區分 -->
                                                        <DataTrigger Binding="{Binding IsHintPending}" Value="True">
                                                            <Setter Property="Opacity" Value="0.45" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.8"
                                                                  Color="#FFBE6E1A" />
                                            </Border.Effect>
                                        </Border>

                                        <!-- 底盤漸層 (立體陰影) -->
                                        <Ellipse Width="46" Height="46">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource RedPieceDiscBrush}" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="3.5"
                                                                              Opacity="0.55" Color="#2A1000"
                                                                              Direction="280" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Piece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Fill" Value="{StaticResource BlackPieceDiscBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- 外環 -->
                                        <Ellipse Width="46" Height="46" Fill="Transparent">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Stroke" Value="{StaticResource RedPieceRingBrush}" />
                                                    <Setter Property="StrokeThickness" Value="2.5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Piece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Stroke" Value="{StaticResource BlackPieceRingBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- 內環 (裝飾) -->
                                        <Ellipse Width="37" Height="37" Fill="Transparent" Opacity="0.7">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Stroke" Value="{StaticResource RedPieceRingBrush}" />
                                                    <Setter Property="StrokeThickness" Value="1.2" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Piece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Stroke" Value="{StaticResource BlackPieceRingBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- 棋字 -->
                                        <TextBlock Text="{Binding Piece, Converter={StaticResource PieceTextConverter}}"
                                                   FontFamily="{StaticResource ChineseClassicFont}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource RedPieceTextBrush}" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="1.5" ShadowDepth="0.5"
                                                                              Opacity="0.25" Color="#000000" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Piece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Foreground" Value="{StaticResource BlackPieceTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 智能提示：虛影棋子（最佳落點，棋子半透明顯示） -->
                                    <Grid Width="46" Height="46"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0.38"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="8"
                                          Visibility="{Binding HasGhostPiece, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Ellipse Width="46" Height="46">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource RedPieceDiscBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GhostPiece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Fill" Value="{StaticResource BlackPieceDiscBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Ellipse Width="46" Height="46" Fill="Transparent">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Stroke" Value="{StaticResource RedPieceRingBrush}" />
                                                    <Setter Property="StrokeThickness" Value="2.5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GhostPiece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Stroke" Value="{StaticResource BlackPieceRingBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding GhostPiece, Converter={StaticResource PieceTextConverter}}"
                                                   FontFamily="{StaticResource ChineseClassicFont}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource RedPieceTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GhostPiece.Color}"
                                                                     Value="{x:Static enums:PieceColor.Black}">
                                                            <Setter Property="Foreground" Value="{StaticResource BlackPieceTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 智能提示：評分數字（右下角，黑色半透明背景，文字依正負著色） -->
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,1,1"
                                            CornerRadius="3"
                                            Padding="2,1"
                                            IsHitTestVisible="False"
                                            Panel.ZIndex="15"
                                            Background="#CC000000"
                                            Visibility="{Binding HasSmartHint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding SmartHintScoreText}"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding SmartHintScore, Converter={StaticResource SmartHintScoreToBrushConverter}}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <!-- 上一步終點：亮色外環覆蓋在棋子上 -->
                                    <Border x:Name="LastMoveToRing"
                                            Width="46" Height="46"
                                            BorderBrush="{StaticResource LastMoveDestBrush}"
                                            BorderThickness="3"
                                            CornerRadius="23"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsLastMoveTo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                                              Opacity="0.85" Color="#FF9D2A" />
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
