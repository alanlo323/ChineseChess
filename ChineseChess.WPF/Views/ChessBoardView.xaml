<UserControl x:Class="ChineseChess.WPF.Views.ChessBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChessBoardViewModel}"
             Height="560" Width="540">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BoardHoverBrush" Color="#B58F5F" />
        <SolidColorBrush x:Key="BoardPressedBrush" Color="#8D6A3A" />
        <SolidColorBrush x:Key="SelectedGlowBrush" Color="#F2E08E" />

        <Style x:Key="SquareButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BoardLineBrush}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SquareFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SquareFrame" Property="Background" Value="{StaticResource BoardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SquareFrame" Property="Background" Value="{StaticResource BoardPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SquareFrame" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PieceTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource ChineseClassicFont}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource BoardSurfaceBrush}"
                BorderBrush="{StaticResource BoardLineBrush}"
                BorderThickness="3"
                CornerRadius="8">
            <Border Background="#22000000" Opacity="0.08" />
        </Border>

        <ItemsControl ItemsSource="{Binding Squares}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="10" Columns="9" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource SquareButtonStyle}"
                            Command="{Binding DataContext.SquareClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                        <Grid>
                            <Border x:Name="SelectionRing"
                                    Width="42"
                                    Height="42"
                                    BorderBrush="{StaticResource SelectedGlowBrush}"
                                    BorderThickness="3"
                                    CornerRadius="21"
                                    Opacity="0.8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border x:Name="HintFromRing"
                                    Width="44"
                                    Height="44"
                                    BorderBrush="{StaticResource HintFromBrush}"
                                    BorderThickness="3"
                                    CornerRadius="22"
                                    Opacity="0.9"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsHintFrom, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Border x:Name="HintToRing"
                                    Width="46"
                                    Height="46"
                                    BorderBrush="{StaticResource HintToBrush}"
                                    BorderThickness="2"
                                    CornerRadius="23"
                                    Opacity="0.85"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsHintTo, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Ellipse Width="14"
                                     Height="14"
                                     Fill="{StaticResource MoveHintBrush}"
                                     Opacity="0.75"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsValidMove, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Ellipse Width="18"
                                     Height="18"
                                     Fill="{StaticResource HintToBrush}"
                                     Opacity="0.8"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsHintTo, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <TextBlock Text="{Binding Piece, Converter={StaticResource PieceTextConverter}}"
                                       Foreground="{Binding Piece.Color, Converter={StaticResource ColorConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource ChineseClassicFont}" />
                                        <Setter Property="FontSize" Value="30" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="3"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.35"
                                                                  Color="#000000" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Piece.IsNone}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
