<UserControl x:Class="ChineseChess.WPF.Views.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             xmlns:views="clr-namespace:ChineseChess.WPF.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ControlPanelViewModel}">
    <DockPanel Margin="12" LastChildFill="True">

        <!-- 標題區 -->
        <TextBlock DockPanel.Dock="Top"
                   Text="象棋 AI 對弈"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource InkBrush}" />
        <Border DockPanel.Dock="Top"
                Height="1"
                Background="{StaticResource WoodDarkBrush}"
                Opacity="0.35"
                Margin="0,10,0,0" />

        <!-- 棋鐘顯示（限時模式下顯示於最上方）-->
        <Grid DockPanel.Dock="Top"
              Margin="0,8,0,0"
              Visibility="{Binding IsTimedModeSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#FFEECC" CornerRadius="4" Padding="6,4" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="紅方剩餘"
                               Style="{StaticResource FormLabelStyle}"
                               Foreground="#CC2200"
                               FontSize="10"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding RedTimeDisplay}"
                               Style="{StaticResource StatusTextStyle}"
                               Foreground="#CC2200"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#EEE8D5" CornerRadius="4" Padding="6,4" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="黑方剩餘"
                               Style="{StaticResource FormLabelStyle}"
                               Foreground="#222222"
                               FontSize="10"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BlackTimeDisplay}"
                               Style="{StaticResource StatusTextStyle}"
                               Foreground="#222222"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 局面訊息卡 -->
        <Border DockPanel.Dock="Top"
                Style="{StaticResource SubPanelCardStyle}"
                Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusTextStyle}"
                       FontWeight="Medium" />
        </Border>
        <!-- 主要操作列 -->
        <UniformGrid DockPanel.Dock="Top"
                     Columns="4"
                     Margin="0,10,0,0">
            <Button Content="開始對局"
                    Command="{Binding StartGameCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,6,0"
                    Padding="10,8" />
            <Button Content="悔棋"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,6,0"
                    Padding="10,8" />
            <Button Content="提示走法"
                    Command="{Binding HintCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,6,0"
                    Padding="10,8" Cursor="Hand" />
            <Button Content="解釋這一步"
                    Command="{Binding ExplainHintCommand}"
                    IsEnabled="{Binding CanExplainHint}"
                    Style="{StaticResource ActionButtonStyle}"
                    Padding="10,8" />
        </UniformGrid>

        <!-- 擺棋模式按鈕 -->
        <UniformGrid DockPanel.Dock="Top"
                     Columns="1"
                     Margin="0,6,0,0">
            <Button Content="進入擺棋模式"
                    Command="{Binding EnterSetupModeCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Padding="10,8" />
        </UniformGrid>

        <!-- 擺棋模式面板（進入擺棋模式後顯示） -->
        <Border DockPanel.Dock="Top"
                Style="{StaticResource SubPanelCardStyle}"
                Margin="0,6,0,0"
                Visibility="{Binding IsInSetupMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <views:BoardSetupView DataContext="{Binding BoardSetup}" />
        </Border>

        <!-- 提和操作列 -->
        <UniformGrid DockPanel.Dock="Top"
                     Columns="1"
                     Margin="0,6,0,0">
            <Button Content="提和"
                    Command="{Binding RequestDrawCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Padding="10,8" />
        </UniformGrid>

        <!-- TabControl 二分頁 -->
        <TabControl Margin="0,10,0,0"
                    Style="{StaticResource TabControlStyle}"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    ItemContainerStyle="{StaticResource TabItemStyle}">

            <!-- 設定頁 -->
            <TabItem Header="設定">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8">

                        <!-- 遊戲模式 -->
                        <TextBlock Text="遊戲模式"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding GameModes}"
                                  SelectedItem="{Binding SelectedMode}"
                                  Style="{StaticResource InputControlStyle}"
                                  Margin="0,0,0,10" />

                        <!-- 玩家持色（僅 PlayerVsAi 模式顯示）-->
                        <StackPanel Visibility="{Binding IsPlayerVsAiMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,0,10">
                            <TextBlock Text="玩家持色"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding PlayerColorOptions}"
                                      SelectedValue="{Binding PlayerColor}"
                                      SelectedValuePath="Color"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource InputControlStyle}" />
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,0,0,10" />

                        <!-- 思考控制 -->
                        <TextBlock Text="思考控制"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,6" />
                        <UniformGrid Columns="3">
                            <Button Content="停止"
                                    Command="{Binding StopThinkingCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Margin="0,0,6,0" />
                            <Button Content="暫停"
                                    Command="{Binding PauseThinkingCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Margin="0,0,6,0" />
                            <Button Content="繼續"
                                    Command="{Binding ResumeThinkingCommand}"
                                    Style="{StaticResource CompactButtonStyle}" />
                        </UniformGrid>

                        <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />

                        <!-- 搜尋設定（非 AiVsAi 模式）-->
                        <StackPanel Visibility="{Binding IsAiVsAiMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="搜尋設定"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,6" />
                            <!-- 難度等級快選 -->
                            <UniformGrid Columns="4" Margin="0,0,0,6">
                                <Button Content="新手" Style="{StaticResource CompactButtonStyle}"
                                        Command="{Binding SetDifficultyPresetCommand}" CommandParameter="beginner"
                                        Margin="0,0,6,0" ToolTip="深度 2 / 3 秒" />
                                <Button Content="業餘" Style="{StaticResource CompactButtonStyle}"
                                        Command="{Binding SetDifficultyPresetCommand}" CommandParameter="casual"
                                        Margin="0,0,6,0" ToolTip="深度 4 / 8 秒" />
                                <Button Content="進階" Style="{StaticResource CompactButtonStyle}"
                                        Command="{Binding SetDifficultyPresetCommand}" CommandParameter="advanced"
                                        Margin="0,0,6,0" ToolTip="深度 6 / 15 秒" />
                                <Button Content="專家" Style="{StaticResource CompactButtonStyle}"
                                        Command="{Binding SetDifficultyPresetCommand}" CommandParameter="expert"
                                        ToolTip="深度 9 / 25 秒" />
                            </UniformGrid>
                            <!-- 深度（內聯）-->
                            <Grid Margin="0,2,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="深度"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1" Minimum="1" Maximum="10"
                                        Value="{Binding SearchDepth}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Style="{StaticResource DifficultySliderStyle}"
                                        Margin="6,0" Height="20" />
                                <TextBlock Grid.Column="2" Text="{Binding SearchDepth}"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                            <!-- 時間（內聯）：限時模式下隱藏 -->
                            <Grid Margin="0,0,0,4"
                                  Visibility="{Binding IsTimeLimitControlVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="時間"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1" Minimum="1" Maximum="30"
                                        Value="{Binding SearchThinkingTime}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Style="{StaticResource DifficultySliderStyle}"
                                        Margin="6,0" Height="20" />
                                <TextBlock Grid.Column="2" Text="{Binding SearchThinkingTime, StringFormat={}{0}s}"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>

                        <!-- AI 對 AI 個別設定（並排雙欄）-->
                        <StackPanel Visibility="{Binding IsAiVsAiMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 紅方 AI -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="紅方 AI"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Foreground="#CC2200"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="深度"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="1" Maximum="10"
                                                Value="{Binding RedSearchDepth}"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                Style="{StaticResource DifficultySliderStyle}"
                                                Margin="4,0" Height="20" />
                                        <TextBlock Grid.Column="2" Text="{Binding RedSearchDepth}"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4"
                                          Visibility="{Binding IsTimeLimitControlVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="時間"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="1" Maximum="30"
                                                Value="{Binding RedSearchThinkingTime}"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                Style="{StaticResource DifficultySliderStyle}"
                                                Margin="4,0" Height="20" />
                                        <TextBlock Grid.Column="2" Text="{Binding RedSearchThinkingTime, StringFormat={}{0}s}"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <!-- 黑方 AI -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="黑方 AI"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Foreground="#222222"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="深度"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="1" Maximum="10"
                                                Value="{Binding BlackSearchDepth}"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                Style="{StaticResource DifficultySliderStyle}"
                                                Margin="4,0" Height="20" />
                                        <TextBlock Grid.Column="2" Text="{Binding BlackSearchDepth}"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4"
                                          Visibility="{Binding IsTimeLimitControlVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="時間"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="1" Maximum="30"
                                                Value="{Binding BlackSearchThinkingTime}"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                Style="{StaticResource DifficultySliderStyle}"
                                                Margin="4,0" Height="20" />
                                        <TextBlock Grid.Column="2" Text="{Binding BlackSearchThinkingTime, StringFormat={}{0}s}"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- TT 共用選項 -->
                            <CheckBox Content="共用 TT（取消 = 各自獨立 TT）"
                                      IsChecked="{Binding UseSharedTT}"
                                      Foreground="{StaticResource InkBrush}"
                                      Margin="0,4,0,0" />
                            <CheckBox Content="獨立 TT 模式時，黑方開局複製紅方 TT"
                                      IsChecked="{Binding CopyRedTtToBlackAtStart}"
                                      Visibility="{Binding ShowDualTTStats, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Foreground="{StaticResource InkBrush}"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />

                        <!-- 智能提示 -->
                        <CheckBox Content="智能提示（選子時自動分析走法）"
                                  IsChecked="{Binding IsSmartHintEnabled}"
                                  Foreground="{StaticResource InkBrush}"
                                  Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="深度"
                                       Style="{StaticResource FormLabelStyle}"
                                       VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="8"
                                    Value="{Binding SmartHintDepth}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="6,0" Height="20" />
                            <TextBlock Grid.Column="2" Text="{Binding SmartHintDepth}"
                                       Style="{StaticResource FormLabelStyle}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />

                        <!-- MultiPV 提示 -->
                        <CheckBox Content="MultiPV 提示（提示多個最佳著法）"
                                  IsChecked="{Binding IsMultiPvHintEnabled}"
                                  Foreground="{StaticResource InkBrush}"
                                  Margin="0,6,0,6" />
                        <Grid Margin="0,0,0,2"
                              IsEnabled="{Binding IsMultiPvHintEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="著法數"
                                       Style="{StaticResource FormLabelStyle}"
                                       VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="2" Maximum="5"
                                    Value="{Binding MultiPvCount}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Style="{StaticResource DifficultySliderStyle}"
                                    Margin="6,0" Height="20" />
                            <TextBlock Grid.Column="2" Text="{Binding MultiPvCount}"
                                       Style="{StaticResource FormLabelStyle}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />

                        <!-- 限時模式 -->
                        <TextBlock Text="限時模式"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,6" />
                        <CheckBox Content="啟用限時模式（開局時生效）"
                                  IsChecked="{Binding IsTimedModeEnabled}"
                                  Foreground="{StaticResource InkBrush}"
                                  Margin="0,0,0,6" />
                        <!-- 每方時間設定（僅在啟用時顯示）-->
                        <StackPanel Visibility="{Binding IsTimedModeSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="每方"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1" Minimum="1" Maximum="60"
                                        Value="{Binding TimedModeMinutesPerPlayer}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Style="{StaticResource DifficultySliderStyle}"
                                        Margin="6,0" Height="20" />
                                <TextBlock Grid.Column="2" Text="{Binding TimedModeMinutesPerPlayer, StringFormat={}{0} 分}"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>

                        <!-- 外部引擎快速開關 -->
                        <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />
                        <TextBlock Text="外部引擎"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,6" />
                        <CheckBox Content="紅方使用外部引擎"
                                  IsChecked="{Binding IsRedExternalEngineEnabled}"
                                  IsEnabled="{Binding HasRedEngineConfig}"
                                  Foreground="{StaticResource InkBrush}"
                                  Margin="0,0,0,6" />
                        <CheckBox Content="黑方使用外部引擎"
                                  IsChecked="{Binding IsBlackExternalEngineEnabled}"
                                  IsEnabled="{Binding HasBlackEngineConfig}"
                                  Foreground="{StaticResource InkBrush}"
                                  Margin="0,0,0,4" />
                        <TextBlock Text="如需使用外部引擎，請先至「外部引擎」頁完成設定"
                                   Style="{StaticResource FormLabelStyle}"
                                   FontSize="10"
                                   Foreground="#888888" />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 統計頁 -->
            <TabItem Header="統計">
                <DockPanel Margin="0,8">
                    <Button DockPanel.Dock="Bottom"
                            Content="刷新統計"
                            Command="{Binding RefreshTTStatsCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,10,0,0"
                            Padding="10,6" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="搜尋效能"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="已搜尋節點："
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,6,4" />
                                <TextBlock Grid.Column="1" Text="{Binding SearchNodes}"
                                           Style="{StaticResource StatusTextStyle}"
                                           Margin="0,0,10,4" />
                                <TextBlock Grid.Column="2" Text="搜尋速度："
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,6,4" />
                                <TextBlock Grid.Column="3" Text="{Binding SearchNps}"
                                           Style="{StaticResource StatusTextStyle}" />
                            </Grid>

                            <Border Height="1"
                                    Background="{StaticResource WoodDarkBrush}"
                                    Opacity="0.20"
                                    Margin="0,8,0,8" />

                            <!-- 單一 TT（共用或非 AiVsAi 模式）-->
                            <StackPanel Visibility="{Binding ShowDualTTStats, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock Text="置換表 (TT)"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="容量："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TtCapacity}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="有效條目："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding TtOccupied}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="填滿率："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TtFillRate}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="記憶體："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding TtMemoryMb}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="世代："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TtGeneration}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="查詢："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding TtProbes}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="命中："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TtHits}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="命中率："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding TtHitRate}"
                                               Style="{StaticResource StatusTextStyle}" />
                                </Grid>
                            </StackPanel>

                            <!-- 雙 TT（AI 對 AI + 獨立 TT 模式）-->
                            <StackPanel Visibility="{Binding ShowDualTTStats, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- 紅方 TT -->
                                <TextBlock Text="紅方置換表 (TT)"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Foreground="#CC2200"
                                           Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="容量："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TtCapacity}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="有效條目："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding TtOccupied}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="填滿率："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TtFillRate}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="記憶體："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding TtMemoryMb}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="世代："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TtGeneration}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="查詢："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding TtProbes}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="命中："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TtHits}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="命中率："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding TtHitRate}"
                                               Style="{StaticResource StatusTextStyle}" />
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource WoodDarkBrush}"
                                        Opacity="0.20"
                                        Margin="0,10,0,10" />

                                <!-- 黑方 TT -->
                                <TextBlock Text="黑方置換表 (TT)"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Foreground="#222222"
                                           Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="容量："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BlackTtCapacity}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="有效條目："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding BlackTtOccupied}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="填滿率："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BlackTtFillRate}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="記憶體："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BlackTtMemoryMb}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="世代："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BlackTtGeneration}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="查詢："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding BlackTtProbes}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="命中："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BlackTtHits}"
                                               Style="{StaticResource StatusTextStyle}" Margin="0,0,10,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="命中率："
                                               Style="{StaticResource FormLabelStyle}" Margin="0,0,6,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding BlackTtHitRate}"
                                               Style="{StaticResource StatusTextStyle}" />
                                </Grid>
                            </StackPanel>

                            <!-- TT 操作 -->
                            <Border Height="1" Background="{StaticResource WoodDarkBrush}" Opacity="0.20" Margin="0,10,0,10" />
                            <TextBlock Text="TT 操作"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,6" />

                            <!-- 單一 TT 操作（共用 TT 或非 AiVsAi 模式）-->
                            <UniformGrid Columns="2" Margin="0,0,0,0"
                                         Visibility="{Binding ShowDualTTStats, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Button Content="匯出 TT"
                                        Command="{Binding ExportTranspositionTableCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,6,0" />
                                <Button Content="匯入 TT"
                                        Command="{Binding ImportTranspositionTableCommand}"
                                        Style="{StaticResource CompactButtonStyle}" />
                            </UniformGrid>

                            <!-- 雙 TT 操作（AI 對 AI + 獨立 TT 模式）-->
                            <StackPanel Visibility="{Binding ShowDualTTStats, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="紅方" Style="{StaticResource FormLabelStyle}"
                                           Foreground="#CC2200" Margin="0,0,0,4" />
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button Content="匯出紅方 TT"
                                            Command="{Binding ExportTranspositionTableCommand}"
                                            Style="{StaticResource CompactButtonStyle}"
                                            Margin="0,0,6,0" />
                                    <Button Content="匯入紅方 TT"
                                            Command="{Binding ImportTranspositionTableCommand}"
                                            Style="{StaticResource CompactButtonStyle}" />
                                </UniformGrid>
                                <TextBlock Text="黑方" Style="{StaticResource FormLabelStyle}"
                                           Foreground="#222222" Margin="0,0,0,4" />
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button Content="匯出黑方 TT"
                                            Command="{Binding ExportBlackTranspositionTableCommand}"
                                            Style="{StaticResource CompactButtonStyle}"
                                            Margin="0,0,6,0" />
                                    <Button Content="匯入黑方 TT"
                                            Command="{Binding ImportBlackTranspositionTableCommand}"
                                            Style="{StaticResource CompactButtonStyle}" />
                                </UniformGrid>
                                <Button Content="合併兩方 TT"
                                        Command="{Binding MergeTranspositionTablesCommand}"
                                        Style="{StaticResource CompactButtonStyle}" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- TT 探索頁 -->
            <TabItem Header="TT 探索">
                <DockPanel Margin="0,8">
                    <!-- 合併輸出（條目分布 + 思路樹）-->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding TTExplorerText}"
                                   Style="{StaticResource FormLabelStyle}"
                                   FontFamily="Consolas, Courier New"
                                   FontSize="11"
                                   TextWrapping="NoWrap" />
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="提示">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,6">

                        <!-- MultiPV 結果列表（啟用 MultiPV 時顯示）-->
                        <StackPanel Visibility="{Binding IsMultiPvHintEnabled,
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="多著法分析"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding MultiPvItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding SelectCommand}"
                                                Cursor="Hand" Margin="0,0,0,4"
                                                Focusable="False">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="4" Padding="6,4"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#F5F5F5" />
                                                                <Setter Property="BorderBrush" Value="#DDDDDD" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                                        <Setter Property="BorderBrush" Value="#388E3C" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="22" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Rank, StringFormat={}#{0}}"
                                                                       Style="{StaticResource FormLabelStyle}"
                                                                       FontWeight="Bold" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Notation}"
                                                                       Style="{StaticResource StatusTextStyle}"
                                                                       FontWeight="SemiBold" Margin="6,0" />
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding PvLine}"
                                                                       Style="{StaticResource FormLabelStyle}"
                                                                       FontSize="10" Foreground="#888888"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding ScoreText}"
                                                                       Style="{StaticResource StatusTextStyle}"
                                                                       FontWeight="Bold" Margin="6,0,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Height="1" Background="{StaticResource WoodDarkBrush}"
                                    Opacity="0.20" Margin="0,8,0,8" />
                        </StackPanel>

                        <!-- 提示解釋（原有內容保留）-->
                        <TextBlock Text="提示解釋"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="{Binding HintExplanationText}"
                                   Style="{StaticResource StatusTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="局面分析">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,6">
                        <!-- 免責聲明 -->
                        <Border Background="#FFF3E0"
                                CornerRadius="4"
                                Padding="8"
                                Margin="0,0,0,8">
                            <TextBlock Text="{Binding GameAnalysisDisclaimer}"
                                       Foreground="#E65100"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource FormLabelStyle}" />
                        </Border>
                        <!-- 啟用/停用 -->
                        <CheckBox Content="啟用 AI 局面分析（AI 走子後自動更新）"
                                  IsChecked="{Binding IsGameAnalysisEnabled}"
                                  Foreground="{StaticResource InkBrush}"
                                  Margin="0,0,0,8" />
                        <!-- 分析中指示 -->
                        <TextBlock Text="AI 分析中..."
                                   Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Style="{StaticResource FormLabelStyle}"
                                   FontStyle="Italic"
                                   Margin="0,0,0,4" />
                        <!-- 分析內容 -->
                        <TextBlock Text="{Binding GameAnalysisText}"
                                   Style="{StaticResource StatusTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 外部引擎頁 -->
            <TabItem Header="外部引擎">
                <views:ExternalEngineView DataContext="{Binding ExternalEngine}" />
            </TabItem>

            <!-- NNUE 頁 -->
            <TabItem Header="NNUE">
                <views:NnueView DataContext="{Binding Nnue}" />
            </TabItem>

            <!-- 棋譜頁 -->
            <TabItem Header="棋譜">
                <views:MoveHistoryView DataContext="{Binding MoveHistory}" />
            </TabItem>

            <!-- 殘局庫頁 -->
            <TabItem Header="殘局庫">
                <views:EndgameTablebView DataContext="{Binding EndgameTableb}" />
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
