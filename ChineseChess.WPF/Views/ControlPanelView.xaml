<UserControl x:Class="ChineseChess.WPF.Views.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:ControlPanelViewModel}"
             Width="250">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <TextBlock Text="象棋演算法對弈"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource InkBrush}" />

            <Border Style="{StaticResource SubPanelCardStyle}" Margin="0,12,0,12">
                <StackPanel>
                    <TextBlock Text="局面訊息"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusTextStyle}"
                               Margin="0,6,0,0"
                               FontWeight="Medium" />
                </StackPanel>
            </Border>

            <GroupBox Header="設定"
                      Style="{StaticResource PanelGroupStyle}">
                <StackPanel Margin="0,2">
                    <TextBlock Text="遊戲模式" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding GameModes}"
                              SelectedItem="{Binding SelectedMode}"
                              Style="{StaticResource InputControlStyle}"
                              Margin="0,0,0,10" />

                    <TextBlock Text="搜尋深度 (難度)"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,6" />
                    <Slider Minimum="1"
                            Maximum="10"
                            Value="{Binding SearchDepth}"
                            AutoToolTipPlacement="TopLeft"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Style="{StaticResource DifficultySliderStyle}" />
                </StackPanel>
            </GroupBox>

            <Button Content="開始對局"
                    Command="{Binding StartGameCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,14,0,8"
                    Padding="10,8" />

            <Button Content="悔棋"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,0,8"
                    Padding="10,8" />

            <Button Content="提示走法"
                    Command="{Binding HintCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Padding="10,8" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
