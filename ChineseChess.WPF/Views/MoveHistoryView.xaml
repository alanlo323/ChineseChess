<UserControl x:Class="ChineseChess.WPF.Views.MoveHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="260">

    <DockPanel LastChildFill="True">

        <!-- 導覽按鈕列 -->
        <Grid DockPanel.Dock="Top" Margin="4,4,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="◀◀" ToolTip="跳至開頭"
                    Command="{Binding GoToStartCommand}"
                    Padding="4,2" Margin="1,0"/>
            <Button Grid.Column="1" Content="◀" ToolTip="後退一步"
                    Command="{Binding StepBackCommand}"
                    Padding="4,2" Margin="1,0"/>
            <Button Grid.Column="2" Content="▶" ToolTip="前進一步"
                    Command="{Binding StepForwardCommand}"
                    Padding="4,2" Margin="1,0"/>
            <Button Grid.Column="3" Content="▶▶" ToolTip="跳至最新"
                    Command="{Binding GoToEndCommand}"
                    Padding="4,2" Margin="1,0"/>

            <TextBlock Grid.Column="4"
                       Text="{Binding StepIndicator}"
                       VerticalAlignment="Center"
                       Margin="6,0,2,0"
                       FontSize="11"
                       Foreground="#555"/>
        </Grid>

        <!-- 進入重播按鈕（Live 模式顯示）-->
        <Button DockPanel.Dock="Top"
                Content="進入重播模式"
                Command="{Binding EnterReplayCommand}"
                Visibility="{Binding IsLive, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="4,2" Padding="4,3"/>

        <!-- 匯出/匯入 -->
        <Grid DockPanel.Dock="Bottom" Margin="4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="匯出棋局"
                    Command="{Binding ExportGameCommand}"
                    Margin="0,0,2,0" Padding="4,3"/>
            <Button Grid.Column="1" Content="匯入棋局"
                    Command="{Binding ImportGameCommand}"
                    Margin="2,0,0,0" Padding="4,3"/>
        </Grid>

        <!-- 從此局面繼續（重播模式才顯示）-->
        <Border DockPanel.Dock="Bottom"
                Visibility="{Binding IsReplaying, Converter={StaticResource BooleanToVisibilityConverter}}"
                BorderBrush="#CCBBAA" BorderThickness="0,1,0,0"
                Margin="4,2" Padding="4">
            <StackPanel>
                <TextBlock Text="── 從此局面繼續 ──"
                           FontSize="11" Foreground="#777"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="模式：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableModes}"
                              SelectedItem="{Binding SelectedContinueMode}"/>
                </Grid>
                <Button Content="開始新對局"
                        Command="{Binding ContinueFromHereCommand}"
                        Padding="4,4" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- 步法列表 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="moveListBox"
                     ItemsSource="{Binding Steps}"
                     BorderThickness="0"
                     SelectionMode="Single"
                     Background="Transparent">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="Background" Value="#FFE8CC"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- 目前步指示箭頭 -->
                            <TextBlock Grid.Column="0"
                                       Text="►"
                                       FontSize="9"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayText}"
                                       FontFamily="Microsoft YaHei, SimSun"
                                       FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <!-- 點擊條目時跳轉到該步 -->
                <ListBox.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding NavigateToStepCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}"/>
                </ListBox.InputBindings>
            </ListBox>
        </ScrollViewer>

    </DockPanel>
</UserControl>
