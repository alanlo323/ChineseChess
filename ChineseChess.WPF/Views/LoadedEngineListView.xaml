<UserControl x:Class="ChineseChess.WPF.Views.LoadedEngineListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LoadedEngineListViewModel}">

    <StackPanel>

        <!-- ─── 新增引擎按鈕列 ──────────────────────────────── -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="新增引擎..."
                    Command="{Binding AddEngineCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,8,0" />

            <!-- 載入中 / 狀態訊息 -->
            <TextBlock Grid.Column="1"
                       Text="{Binding AddStatusMessage}"
                       Style="{StaticResource StatusTextStyle}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </Grid>

        <!-- ─── 引擎列表 ────────────────────────────────────── -->
        <ListBox ItemsSource="{Binding Engines}"
                 SelectedItem="{Binding SelectedEngine}"
                 MaxHeight="180"
                 BorderThickness="1"
                 BorderBrush="{StaticResource WoodDarkBrush}"
                 Background="{StaticResource PanelBackgroundBrush}"
                 Margin="0,0,0,6">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:LoadedEngineItemViewModel}">
                    <Grid Margin="2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 協議徽章 -->
                        <Border Grid.Column="0"
                                CornerRadius="3"
                                Background="{StaticResource WoodDarkBrush}"
                                Padding="4,1"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Protocol}"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold" />
                        </Border>

                        <!-- 引擎名稱 + ELO + 狀態 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding EngineName}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding EloDisplay}"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 重新載入按鈕 -->
                        <Button Grid.Column="2"
                                Content="重載"
                                Command="{Binding ReloadCommand}"
                                Style="{StaticResource CompactButtonStyle}"
                                Width="40"
                                Margin="4,0" />

                        <!-- 卸載按鈕 -->
                        <Button Grid.Column="3"
                                Content="卸載"
                                Command="{Binding RemoveCommand}"
                                Style="{StaticResource CompactButtonStyle}"
                                Width="40" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ─── 詳細資訊面板（選取引擎時顯示）────────────────── -->
        <Border BorderBrush="{StaticResource WoodDarkBrush}"
                BorderThickness="1"
                CornerRadius="3"
                Background="{StaticResource PanelBackgroundBrush}"
                Padding="8,6"
                Visibility="{Binding SelectedEngine, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="引擎詳情"
                           Style="{StaticResource SectionTitleStyle}"
                           FontSize="12"
                           Margin="0,0,0,4" />

                <!-- 路徑 -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="路徑："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedEngine.ExecutablePath}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SelectedEngine.ExecutablePath}" />
                </Grid>

                <!-- 作者 -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="作者："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedEngine.EngineAuthor}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>

                <!-- 協議 -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="協議："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedEngine.Protocol}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>

                <!-- ELO -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ELO："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedEngine.EloDisplay}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>

                <!-- 載入時間 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="載入時間："
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedEngine.DiscoveredAt, StringFormat=yyyy-MM-dd HH:mm}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="11" />
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
