<Window x:Class="ChineseChess.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ChineseChess.WPF.Views"
        xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Chinese Chess AI"
        Height="800" Width="980" MinWidth="900" MinHeight="640"
        WindowState="Maximized"
        Style="{StaticResource AppWindowStyle}">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.55" />
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="18"
                                     To="0"
                                     Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="18" />
        </Grid.RenderTransform>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,12,12">
                <Viewbox Stretch="Uniform" Margin="10">
                    <views:ChessBoardView DataContext="{Binding ChessBoard}" />
                </Viewbox>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,0,12">
                <views:ControlPanelView DataContext="{Binding ControlPanel}" />
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="棋局觀測"
                               Style="{StaticResource SectionHeadingStyle}" />

                    <Border Grid.Row="1"
                            Style="{StaticResource SubPanelCardStyle}"
                            Margin="0,6,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding AnalysisText}"
                                       Style="{StaticResource AnalysisTextStyle}" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
