<Window x:Class="ChineseChess.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ChineseChess.WPF.Views"
        xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="象棋 AI 對弈"
        Icon="/Resources/app.ico"
        Height="800" Width="1085" MinWidth="900" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindowStyle}">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.55" />
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="18"
                                     To="0"
                                     Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="18" />
        </Grid.RenderTransform>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="480" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" MinHeight="60" MaxHeight="90" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,16,16">
                <Viewbox Stretch="Uniform" Margin="10">
                    <!-- 包裝層：座標與棋盤同步縮放，完全獨立於棋子層 -->
                    <Grid Width="540">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>

                        <!-- 頂部：黑方座標（阿拉伯數字半形，由左至右 = 黑方右為1路）
                             Canvas.Left = 22 + k*60（欄中心 x = 30 + k*60，偏移8px置中16px文字） -->
                        <Canvas Grid.Row="0" IsHitTestVisible="False">
                            <TextBlock Text="1" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="22"  Canvas.Top="4" />
                            <TextBlock Text="2" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="82"  Canvas.Top="4" />
                            <TextBlock Text="3" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="142" Canvas.Top="4" />
                            <TextBlock Text="4" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="202" Canvas.Top="4" />
                            <TextBlock Text="5" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="262" Canvas.Top="4" />
                            <TextBlock Text="6" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="322" Canvas.Top="4" />
                            <TextBlock Text="7" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="382" Canvas.Top="4" />
                            <TextBlock Text="8" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="442" Canvas.Top="4" />
                            <TextBlock Text="9" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="502" Canvas.Top="4" />
                        </Canvas>

                        <views:ChessBoardView Grid.Row="1" DataContext="{Binding ChessBoard}" />

                        <!-- 底部：紅方座標（漢字，由左至右 = 紅方右為一路） -->
                        <Canvas Grid.Row="2" IsHitTestVisible="False">
                            <TextBlock Text="九" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="22"  Canvas.Top="4" />
                            <TextBlock Text="八" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="82"  Canvas.Top="4" />
                            <TextBlock Text="七" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="142" Canvas.Top="4" />
                            <TextBlock Text="六" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="202" Canvas.Top="4" />
                            <TextBlock Text="五" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="262" Canvas.Top="4" />
                            <TextBlock Text="四" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="322" Canvas.Top="4" />
                            <TextBlock Text="三" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="382" Canvas.Top="4" />
                            <TextBlock Text="二" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="442" Canvas.Top="4" />
                            <TextBlock Text="一" FontFamily="{StaticResource ChineseClassicFont}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WoodMidBrush}" Opacity="1.0" Width="18" TextAlignment="Center" Canvas.Left="502" Canvas.Top="4" />
                        </Canvas>
                    </Grid>
                </Viewbox>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,0,16">
                <views:ControlPanelView DataContext="{Binding ControlPanel}" />
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="棋局觀測"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,4" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding AnalysisText}"
                                   Style="{StaticResource AnalysisTextStyle}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
