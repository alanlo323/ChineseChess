<UserControl x:Class="ChineseChess.WPF.Views.BoardSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ChineseChess.WPF.ViewModels"
             xmlns:enums="clr-namespace:ChineseChess.Domain.Enums;assembly=ChineseChess.Domain"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BoardSetupViewModel}">
   <StackPanel Margin="0,8,0,0">

        <TextBlock Text="【擺棋模式】"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{StaticResource InkBrush}"
                   Margin="0,0,0,8" />

        <!-- 棋子調色板：上排紅方 / 下排黑方 -->
        <TextBlock Text="選取棋子："
                   Style="{StaticResource FormLabelStyle}"
                   Margin="0,0,0,4" />
        <ListBox ItemsSource="{Binding PiecePalette}"
                 SelectedItem="{Binding SelectedPiece, Mode=TwoWay}"
                 Style="{StaticResource PiecePaletteListBoxStyle}"
                 Margin="0,0,0,6">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource PiecePaletteItemStyle}" />
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="40" Height="40">
                        <Ellipse Width="40" Height="40">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource RedPieceDiscBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Color}"
                                                     Value="{x:Static enums:PieceColor.Black}">
                                            <Setter Property="Fill" Value="{StaticResource BlackPieceDiscBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Ellipse Width="40" Height="40" Fill="Transparent">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Stroke" Value="{StaticResource RedPieceRingBrush}" />
                                    <Setter Property="StrokeThickness" Value="2" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Color}"
                                                     Value="{x:Static enums:PieceColor.Black}">
                                            <Setter Property="Stroke" Value="{StaticResource BlackPieceRingBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Ellipse Width="32" Height="32" Fill="Transparent" Opacity="0.7">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Stroke" Value="{StaticResource RedPieceRingBrush}" />
                                    <Setter Property="StrokeThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Color}"
                                                     Value="{x:Static enums:PieceColor.Black}">
                                            <Setter Property="Stroke" Value="{StaticResource BlackPieceRingBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding Converter={StaticResource PieceTextConverter}}"
                                   FontFamily="{StaticResource ChineseClassicFont}"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource RedPieceTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Color}"
                                                     Value="{x:Static enums:PieceColor.Black}">
                                            <Setter Property="Foreground" Value="{StaticResource BlackPieceTextBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 橡皮擦模式 -->
        <ToggleButton Content="橡皮擦"
                      IsChecked="{Binding IsEraseMode, Mode=TwoWay}"
                      Style="{StaticResource EraseModeToggleStyle}"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,8" />

        <!-- 行棋方 -->
        <TextBlock Text="行棋方："
                   Style="{StaticResource FormLabelStyle}"
                   Margin="0,0,0,4" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <RadioButton Content="紅方先手" IsChecked="{Binding SetupTurn, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Red}"
                         Margin="0,0,12,0" Foreground="#CC2200" />
            <RadioButton Content="黑方先手" IsChecked="{Binding SetupTurn, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Black}"
                         Foreground="#222222" />
        </StackPanel>

        <!-- 遊戲模式 -->
        <TextBlock Text="遊戲模式："
                   Style="{StaticResource FormLabelStyle}"
                   Margin="0,0,0,4" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <RadioButton Content="人 vs AI"
                         IsChecked="{Binding TargetMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=PlayerVsAi}"
                         Margin="0,0,12,0" />
            <RadioButton Content="人 vs 人"
                         IsChecked="{Binding TargetMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=PlayerVsPlayer}"
                         Margin="0,0,12,0" />
            <RadioButton Content="AI vs AI"
                         IsChecked="{Binding TargetMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AiVsAi}" />
        </StackPanel>

        <!-- 操作按鈕 -->
        <UniformGrid Columns="2" Margin="0,0,0,8">
            <Button Content="清空棋盤"
                    Command="{Binding ClearBoardCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,4,0"
                    Padding="8,6" />
            <Button Content="重置初始局"
                    Command="{Binding ResetBoardCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="4,0,0,0"
                    Padding="8,6" />
        </UniformGrid>

        <Button Content="確認局面 / 開始對局"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ActionButtonStyle}"
                Padding="10,8"
                Margin="0,0,0,8" />

        <!-- 驗證訊息 -->
        <TextBlock Text="{Binding ValidationMessage}"
                   Foreground="{Binding IsValid, Converter={StaticResource BoolToValidationColorConverter}}"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <!-- 提示說明 -->
        <Border Background="#FFF8E7" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="#664400">
                <Run Text="左鍵" FontWeight="Bold" />
                <Run Text="：放置選取棋子" />
                <LineBreak />
                <Run Text="橡皮擦" FontWeight="Bold" />
                <Run Text=" + 左鍵：移除棋子" />
                <LineBreak />
                <Run Text="（右鍵亦可直接移除）" />
            </TextBlock>
        </Border>

    </StackPanel>
</UserControl>
